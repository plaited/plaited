      "@id": "corpus:seed-insufficiency-1",
      "@type": "corpus:SeedInsufficiency",
      "rdfs:label": "Agent card MSS metadata projection",
      "corpus:description": "The MSS SKILL.md describes agent card integration in broad strokes but does not specify the exact metadata key format for MSS projection into agent cards. The modnet-node skill uses 'modnet:mss:contentType' style keys but this is implementation-specific, not part of the formal MSS seed ontology.",
      "corpus:insufficiencyType": "runtime-pattern",
      "corpus:requiresExternalValidation": true,
      "derivedFrom": "skills/mss/SKILL.md §Agent Card Integration",
      "corpus:note": "This is a seed insufficiency that should be addressed in future seed revisions if agent card metadata projection becomes a formal MSS concern."
    },
    {
      "@id": "corpus:seed-insufficiency-2",
      "@type": "corpus:SeedInsufficiency",
      "rdfs:label": "Scale S4 definition",
      "corpus:description": "The seed does not provide explicit guidance on S4 (Block Group) semantics beyond 'arranges multiple blocks spatially' and 'rare'. The modnet-node skill provides more concrete guidance (spatial arrangement between participants) but this is not formally in the seed.",
      "corpus:insufficiencyType": "conceptual-gap",
      "corpus:requiresExternalValidation": false,
      "derivedFrom": "skills/modnet-node/SKILL.md §Scale: S2 vs S3 vs S4",
      "corpus:note": "S4 guidance is primarily derived from modnet-node skill rather than formal seed. This may be appropriate as modnet-node provides operational guidance."
    },
