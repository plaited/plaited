  "@graph": [
    {
      "@id": "corpus:assertion-contentType-inference",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "contentType inference principle",
      "mss:description": "contentType is inferred from context, not selected from a fixed registry. Ask: 'If this artifact participates in a broader system, what other artifacts should it align or interoperate with?'",
      "mss:field": "contentType",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:contentType",
      "mss:distilledFrom": "skills/mss/SKILL.md §1. contentType"
    },
    {
      "@id": "corpus:assertion-contentType-translation",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "contentType agent translation",
      "mss:description": "contentTypes do not need to align globally. An agent can translate. A commerce network might produce a health-aligned view if the user cares about nutrition.",
      "mss:field": "contentType",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:contentType",
      "mss:distilledFrom": "skills/mss/SKILL.md §1. contentType"
    },
    {
      "@id": "corpus:assertion-structure-decision-tree",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Structure decision tree",
      "mss:description": "Ask 'What is the user doing with the data right now, and how is it being presented?' Decision tree: single item→object, input/creation→form, defined order→list, grouped without order→collection, multi-page goal→steps, hierarchical nesting→pool, chronological scroll→stream, algorithm-sorted→feed, profile+stream→wall, nested replies→thread, platform nav→hierarchy/matrix/daisy/hypertext",
      "mss:field": "structure",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:structure",
      "mss:distilledFrom": "skills/mss/SKILL.md §2. structure"
    },
    {
      "@id": "corpus:assertion-structure-scale-compatibility",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Structure-scale compatibility table",
      "mss:description": "S1: object, form. S2: object, list, collection, steps, form. S3: pool, stream, feed, wall, thread, form, collection, steps. S4-S6: Any from lower scales, composed. S7: hierarchy, matrix, daisy, hypertext, pool, collection. S8: Federated compositions.",
      "mss:field": "structure",
      "mss:relatedField": "scale",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:invariant_scale-structure-compatibility",
      "mss:distilledFrom": "skills/mss/SKILL.md §2. structure"
    },
    {
      "@id": "corpus:assertion-mechanics-capability-declaration",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Mechanics are capability declarations",
      "mss:description": "Mechanics tags declare potential interactions. They activate when the current context, structure, and boundary support them. A standalone artifact can expose a very different UI from the same artifact when mediated through another agent or larger composition.",
      "mss:field": "mechanics",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:mechanics",
      "mss:distilledFrom": "skills/mss/SKILL.md §3. mechanics"
    },
    {
      "@id": "corpus:assertion-mechanics-conservative-tagging",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Conservative mechanics tagging",
      "mss:description": "Only tag mechanics that the description explicitly names or clearly implies. If the description doesn't mention filtering, sorting, charting, or sharing, don't add them even if they could theoretically apply.",
      "mss:field": "mechanics",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:mechanics",
      "mss:distilledFrom": "skills/mss/SKILL.md §3. mechanics"
    },
    {
      "@id": "corpus:assertion-mechanics-evolution",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Mechanics evolution tagging",
      "mss:description": "When a module evolves, re-evaluate mechanics from scratch based on the new description. Don't carry forward old mechanics unless the new description still supports them.",
      "mss:field": "mechanics",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:mechanics",
      "mss:distilledFrom": "skills/mss/SKILL.md §3. mechanics"
    },
    {
      "@id": "corpus:assertion-mechanics-inheritance-bottomup",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Mechanics inheritance: bottom-up",
      "mss:description": "Child module mechanics project onto parent view. Example: food tracking → health icons on farm stand items.",
      "mss:field": "mechanics",
      "mss:provenance": "skills/mss/SKILL.md, skills/mss/references/modnet-standards-distilled.md",
      "mss:seedAnchor": "mss:heuristic_mechanics-inheritance",
      "mss:distilledFrom": "skills/mss/SKILL.md §3. mechanics, skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "corpus:assertion-mechanics-inheritance-topdown",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Mechanics inheritance: top-down",
      "mss:description": "Parent mechanics available to children. Example: density heatmap over farm stalls.",
      "mss:field": "mechanics",
      "mss:provenance": "skills/mss/SKILL.md, skills/mss/references/modnet-standards-distilled.md",
      "mss:seedAnchor": "mss:heuristic_mechanics-inheritance",
      "mss:distilledFrom": "skills/mss/SKILL.md §3. mechanics, skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "corpus:assertion-boundary-four-values",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Boundary four valid values",
      "mss:description": "all: data flows freely. none: no data leaves. ask: user prompted before sharing. paid: sharing requires value exchange.",
      "mss:field": "boundary",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/mss/SKILL.md §4. boundary"
    },
    {
      "@id": "corpus:assertion-boundary-cascade",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Boundary cascade rule",
      "mss:description": "Effective boundary = min(own, parent) where restriction order is none > paid > ask > all. A boundary of 'none' on any ancestor forces all descendant modules to effective boundary 'none'.",
      "mss:field": "boundary",
      "mss:provenance": "skills/mss/SKILL.md, skills/mss/references/modnet-standards-distilled.md",
      "mss:seedAnchor": "mss:invariant_boundary-cascade",
      "mss:distilledFrom": "skills/mss/SKILL.md §4. boundary, skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "corpus:assertion-boundary-decision-signals",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Boundary decision signals",
      "mss:description": "none: private/personal data (health, finance, notes, drawings, playlists). all: stateless tool or public content without account. ask: social/collaborative, commerce/transactions, community with signup. paid: research/data requiring payment.",
      "mss:field": "boundary",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/mss/SKILL.md §4. boundary"
    },
    {
      "@id": "corpus:assertion-scale-eight-levels",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Scale eight levels",
      "mss:description": "S1: singular object. S2: object group. S3: block. S4: block group. S5: module. S6: module group. S7: platform structure. S8: super-structure (federation).",
      "mss:field": "scale",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/mss/SKILL.md §5. scale"
    },
    {
      "@id": "corpus:assertion-scale-nesting-rule",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Scale nesting transitivity",
      "mss:description": "A module at scale N can only be contained by modules at scale > N. A module at scale N can only contain modules at scale < N. Nesting is transitive: S1 inside S2 inside S3 is valid.",
      "mss:field": "scale",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:invariant_scale-nesting",
      "mss:distilledFrom": "skills/mss/SKILL.md §5. scale"
    },
    {
      "@id": "corpus:assertion-lifecycle-four-phases",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Artifact lifecycle four phases",
      "mss:description": "Phase 1 Create: personal intent, boundary none/all, scale S1-S2. Phase 2 Compose: building alongside existing, contentType alignment. Phase 3 Evolve: boundary and scale transitions. Phase 4 Network: capability declaration via MSS fields.",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:lifecycle_phase1-create",
      "mss:distilledFrom": "skills/mss/SKILL.md §Artifact Lifecycle"
    },
    {
      "@id": "corpus:assertion-network-emergent-formation",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Emergent network formation",
      "mss:description": "Emergent grouping and promotion are useful defaults, not rigid universal laws. In agent-mediated systems the agent may: (1) align two artifacts into a shared group, (2) keep them distinct but query-compatible, (3) generate an intermediate view, (4) or decline composition because boundary or user intent blocks it.",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:rule_network-formation",
      "mss:distilledFrom": "skills/mss/SKILL.md §Composition Rules"
    },
    {
      "@id": "corpus:assertion-agent-card-mss-integration",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Agent card MSS integration",
      "mss:description": "The agent card should indicate that the agent supports MSS-aware interaction. It does not need to expose a full global registry of MSS values inline. Network uses: discovery (identify MSS-aware agents), consent (boundary determines sharing), alignment (query contentType/structure/mechanics), composition (generated UI replaces template registries).",
      "mss:provenance": "skills/mss/SKILL.md",
      "mss:seedAnchor": "mss:networkUses",
      "mss:distilledFrom": "skills/mss/SKILL.md §Agent Card Integration"
    }
  ]
}
