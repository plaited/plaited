  "@graph": [
    {
      "@id": "corpus:assertion-modnet-node-topology",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Modnet 1 node : 1 user topology",
      "mss:description": "A modnet is a network of user-owned nodes connected peer-to-peer via A2A. Each node is one agent serving one user. There is no central server, no shared tenancy, no platform operator. Each node owns its own memory, constitution, and Agent Card.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Node Topology"
    },
    {
      "@id": "corpus:assertion-module-boundary-model",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Module boundary model",
      "mss:description": "Modules are internal node artifacts: code, data, skills, tools, bThreads, and local memory. They do not cross A2A boundaries directly. Nodes expose services and artifacts through the Agent Card and A2A operations; the underlying module stays internal unless a higher-trust transfer path is explicitly approved.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Module Boundary Model"
    },
    {
      "@id": "corpus:assertion-agent-card-projection",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Agent Card projects capabilities not internals",
      "mss:description": "The Agent Card projects capabilities, not an inventory of internals. Outputs can cross the boundary. Module internals remain node-local by default. Constitution and access-control rules apply at the service/artifact boundary.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Module Boundary Model"
    },
    {
      "@id": "corpus:assertion-node-identity-structural",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Node identity is structural",
      "mss:description": "Node identity is structural: constitution + modules + Agent Card + DAC configuration. Skills are operational tools, not identity.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Key Concepts"
    },
    {
      "@id": "corpus:assertion-mss-module-manifest",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "MSS tags in module package.json",
      "mss:description": "MSS tags live in the 'modnet' field of package.json, validated by ModnetFieldSchema. Example: { modnet: { contentType: 'produce', structure: 'list', mechanics: ['sort', 'filter'], boundary: 'ask', scale: 3 } }",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:fieldAnchors",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Workspace Structure"
    },
    {
      "@id": "corpus:assertion-seed-skill-metadata",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Seed skill MSS metadata",
      "mss:description": "Each module generates a seed skill with MSS metadata as SKILL.md frontmatter fields for PM discovery. The PM reads skills/*/SKILL.md frontmatter to find modules by contentType, scale, or produces/consumes relationships.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:contentType",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Workspace Structure"
    },
    {
      "@id": "corpus:assertion-access-control-three-layers",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Three-layer access control",
      "mss:description": "Three layers compose to gate every cross-boundary request: (1) DAC (Surface) — owner sets boundary tags (all/none/ask/paid), (2) MAC (Floor) — constitution bThreads enforce constraints the owner cannot override, (3) ABAC (Evaluation) — when boundary is ask, BP predicates evaluate requester + module + context.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:invariant_boundary-cascade",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Access Control"
    },
    {
      "@id": "corpus:assertion-block-predicates-policy-engine",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "BP is the single policy engine",
      "mss:description": "Block predicates govern both local tool execution and inter-agent module sharing. MAC: constitution blocks credentials regardless of owner setting. DAC: owner's boundary decision. ABAC: evaluate requester attributes when boundary is ask.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Access Control"
    },
    {
      "@id": "corpus:assertion-payment-gating",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Payment gating via paid boundary",
      "mss:description": "The paid boundary can use HTTP 402 / x402-style payment proofs as an ABAC input. Treat as optional access-control extension. Payment status is modeled as an ABAC attribute.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Access Control"
    },
    {
      "@id": "corpus:assertion-tofu-trust-store",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "TOFU trust store for known-peers",
      "mss:description": "Identity uses TOFU (trust-on-first-use) via createPeerStore. Trust levels progress: untrusted -> tofu -> verified, or -> revoked.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Known-Peers Trust Store"
    },
    {
      "@id": "corpus:assertion-transport-per-interaction",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Transport is per-interaction not per-node",
      "mss:description": "Transport selection is per-interaction, not per-node. Same-box: unix socket. Same-cluster: mTLS. Cross-network: mTLS over internet.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Transport Selection"
    },
    {
      "@id": "corpus:assertion-enterprise-pm-role",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "PM/orchestrator node role",
      "mss:description": "Enterprise deployments use a PM/orchestrator node that provisions infrastructure nodes (registry, observer, gateway) and worker nodes via seed skills.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Enterprise Topology"
    },
    {
      "@id": "corpus:assertion-enterprise-node-roles",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Enterprise node roles",
      "mss:description": "Node roles: pm (orchestrates, manages sub-agents), registry (can't read worker data, can provision/revoke nodes), observer (can't modify nodes, can receive/store audit events), worker (standard agent + org-level MAC).",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Enterprise Topology"
    },
    {
      "@id": "corpus:assertion-mac-ratchet",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "MAC ratchet principle",
      "mss:description": "Org-level bThreads only add constraints, never remove. Workers add DAC preferences on top but cannot weaken the org floor.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:boundary",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Enterprise Topology"
    },
    {
      "@id": "corpus:assertion-skeleton-generation-order",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Skeleton generation reasoning order",
      "mss:description": "When generating a module skeleton from natural language: reason in this order — scale → contentType → structure → mechanics → boundary.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Skeleton Generation Guide"
    },
    {
      "@id": "corpus:assertion-scale-s2-vs-s3-decision",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "S2 vs S3 decision rule",
      "mss:description": "S2 = one group of items. S3 = multiple groups combined into an interactive block. Quick test: count distinct groups. One group → S2. Multiple groups combined into one interactive space → S3.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Scale: S2 vs S3 vs S4"
    },
    {
      "@id": "corpus:assertion-health-domain",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Health domain always health contentType",
      "mss:description": "Fitness/workout/exercise/gym trackers → health (never tools — body/exercise is always health domain).",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:contentType",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §ContentType Defaults"
    },
    {
      "@id": "corpus:assertion-form-vs-collection-tracker",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "form vs collection for trackers",
      "mss:description": "form = primary UI is the INPUT/ENTRY interface itself. collection = items organized BY CATEGORY (category grouping is the primary view). Key test: is the module primarily a VIEW of organized categories? → collection. Or primarily the entry/input screen itself? → form.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:structure",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §form vs collection for Trackers"
    },
    {
      "@id": "corpus:assertion-pool-vs-collection",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "pool vs collection distinction",
      "mss:description": "collection = items grouped by category (flat grouping, no nesting). pool = hierarchical browsing (folders within folders, drill-down navigation). Category filters ('show only restaurants') = collection. Nested folders-in-folders = pool.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:structure",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Structure: collection vs list vs pool"
    },
    {
      "@id": "corpus:assertion-scale-cap-s4-compositions",
      "@type": "mss:CorpusAssertion",
      "rdfs:label": "Scale cap never exceed S4 in compositions",
      "mss:description": "The schema hard cap is scale=4. If a 'coordination workspace' or 'project suite' spatially arranges blocks, it is S4, NOT S5. Do not assign scale=5 under any circumstances.",
      "mss:provenance": "skills/modnet-node/SKILL.md",
      "mss:seedAnchor": "mss:scale",
      "mss:distilledFrom": "skills/modnet-node/SKILL.md §Canonical Composition Hard Cases"
    }
  ]
}
