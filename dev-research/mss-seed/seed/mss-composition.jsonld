{
  "@id": "seed://mss-seed-mss-composition",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/mss-composition.jsonld",
  "layer": "seed",
  "description": "MSS composition rules, lifecycle phases, pattern examples, and anti-patterns. Expresses how modules form networks and how MSS tags evolve over artifact lifecycle.",
  "requires": [
    {
      "@id": "seed://mss-seed-mss-invariants",
      "@type": "Skill"
    }
  ],
  "provides": [
    {
      "@id": "mss:lifecycle/phase1-create",
      "@type": "Concept",
      "description": "Phase 1: Create \u2014 Personal intent. User describes what they want. Agent generates artifact with MSS fields. Boundary typically none (personal) or all (stateless tool). Scale S1-S2. Mechanics reflect personal capabilities."
    },
    {
      "@id": "mss:lifecycle/phase2-compose",
      "@type": "Concept",
      "description": "Phase 2: Compose \u2014 Building alongside existing. Compatible contentType enables grouping or translation. Different contentType uses hyphenated variant to prevent unwanted grouping. Scale follows nesting rules."
    },
    {
      "@id": "mss:lifecycle/phase3-evolve",
      "@type": "Concept",
      "description": "Phase 3: Evolve \u2014 Boundary and scale transitions. boundary progression: none \u2192 ask \u2192 all \u2192 paid. scale promotion: accumulating modules triggers scale increases. New mechanics activate when boundary or structure changes."
    },
    {
      "@id": "mss:lifecycle/phase4-network",
      "@type": "Concept",
      "description": "Phase 4: Network \u2014 Capability declaration. Artifact joins network through agent. MSS fields declare: what it aligns with (contentType), how it shares data (boundary), where it nests (scale), what interactions it supports (mechanics)."
    },
    {
      "@id": "mss:network/emergent-grouping",
      "@type": "Concept",
      "description": "Agent-initiated emergent grouping \u2014 agents may group, translate, or keep artifacts distinct based on intent, boundary, and alignment. Not proximity-triggered automatic self-assembly."
    },
    {
      "@id": "mss:network/assembly-rules",
      "@type": "Concept",
      "references": [
        "mss:field/contentType",
        "mss:field/scale",
        "mss:field/boundary",
        "mss:field/mechanics"
      ],
      "description": "Assembly rules: contentType alignment (strong grouping hint), scale promotion (heuristic), boundary cascade (min rule), mechanics inheritance (top-down and bottom-up)"
    },
    {
      "@id": "mss:network/ephemeral/duration-spectrum",
      "@type": "Concept",
      "description": "Ephemeral networks exist on a duration spectrum: ephemeral-task (minutes-hours), ephemeral-session (hours-days), sticky-subscription (ongoing, repeat:true bThread), permanent-membership (until explicitly left)"
    },
    {
      "@id": "mss:network/ephemeral/search-boundary",
      "@type": "Concept",
      "description": "Search boundary \u2014 how far away you can discover a network. May equal participation boundary (innate ephemeral) or differ (locally ephemeral with designer-set boundaries)"
    },
    {
      "@id": "mss:network/ephemeral/participation-boundary",
      "@type": "Concept",
      "description": "Participation boundary \u2014 how far away you can actively participate. May equal search boundary or differ"
    },
    {
