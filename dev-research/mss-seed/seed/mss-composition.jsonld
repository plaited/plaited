    {
      "@id": "mss:antipattern/feed-at-s1",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/structure-scale-compatible"
      ],
      "description": "structure:feed at scale:S1 is invalid \u2014 feeds require multiple items and temporal ordering"
    },
    {
      "@id": "mss:antipattern/hierarchy-at-s2",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/structure-scale-compatible"
      ],
      "description": "structure:hierarchy at scale:S2 is invalid \u2014 hierarchy is a large-scale navigation structure, not an S2 default"
    },
    {
      "@id": "mss:antipattern/boundary-all-with-health",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:invariant/boundary"
      ],
      "description": "boundary:all with contentType:health is invalid \u2014 health data should not default to open sharing"
    },
    {
      "@id": "mss:antipattern/karma-with-boundary-none",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:invariant/boundary"
      ],
      "description": "mechanics:karma with boundary:none is invalid \u2014 karma requires community interaction and visible exchange"
    },
    {
      "@id": "mss:antipattern/s8-as-object",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/structure-scale-compatible",
        "mss:rule/scale-contains-below"
      ],
      "description": "scale:S8 with structure:object is invalid \u2014 super-structures cannot be singular objects"
    },
    {
      "@id": "mss:antipattern/vote-in-form",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/mechanics-activation-contextual"
      ],
      "description": "mechanics:vote in structure:form is invalid \u2014 voting usually applies to displayed artifacts, not pure input patterns"
    },
    {
      "@id": "mss:antipattern/s5-containing-s6",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/scale-contains-below"
      ],
      "description": "S5 module containing S6 module is invalid \u2014 larger scale cannot be nested inside smaller"
    },
    {
      "@id": "mss:antipattern/gold-with-boundary-none",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:invariant/boundary"
      ],
      "description": "mechanics:gold with boundary:none is invalid \u2014 gold costs real value and requires visible community exchange"
    },
    {
      "@id": "mss:antipattern/post-in-object",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/mechanics-activation-contextual"
      ],
      "description": "mechanics:post in structure:object is invalid \u2014 posting creates new top-level content, requires stream/feed/wall structure"
    },
    {
      "@id": "mss:antipattern/thread-at-s1",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/structure-scale-compatible"
      ],
      "description": "structure:thread at scale:S1 is invalid \u2014 nested replies require multiple levels of content"
    },
    {
      "@id": "mss:antipattern/matrix-at-s1-s3",
      "@type": "AntiPattern",
      "violatedRules": [
        "mss:rule/structure-scale-compatible"
      ],
      "description": "structure:matrix at scale:S1-S3 is invalid \u2014 matrix is a platform navigation structure, S7+ only"
    }
  ]
}