{
  "@id": "seed://mss-seed",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/index.jsonld",
  "layer": "seed",
  "description": "MSS Seed Ontology \u2014 compact, reviewable seed artifacts for downstream corpus and factory compilation. Distilled from MSS SKILL.md, Structural-IA.md, Modnet.md, and MODNET-IMPLEMENTATION.md.",
  "provides": [
    {
      "@id": "mss-seed:namespace",
      "@type": "Concept",
      "description": "MSS seed namespace prefix: mss:, mss:field/, mss:scale/, mss:structure/, mss:mechanics/, mss:boundary/, mss:contentType/, mss:rule/, mss:invariant/, mss:lifecycle/, mss:network/, mss:pattern/ mss:dynamics/, mss:antipattern/"
    },
    {
      "@id": "mss-seed:modnet-namespace",
      "@type": "Concept",
      "description": "Modnet seed namespace prefix: modnet:, agent:mss/, bp:thread/mss-, boundary:"
    },
    {
      "@id": "mss-seed:five-fields",
      "@type": "Concept",
      "references": [
        "mss:field/contentType",
        "mss:field/structure",
        "mss:field/mechanics",
        "mss:field/boundary",
        "mss:field/scale"
      ],
      "description": "The five fixed MSS field names \u2014 field names never vary. See mss-fields.jsonld."
    },
    {
      "@id": "mss-seed:strongest-invariants",
      "@type": "Concept",
      "references": [
        "mss:invariant/boundary",
        "mss:invariant/scale"
      ],
      "description": "boundary and scale are the strongest invariants. See mss-invariants.jsonld."
    },
    {
      "@id": "mss-seed:agent-mediates",
      "@type": "Concept",
      "references": [
        "agent:mss/decode",
        "agent:mss/translate",
        "agent:mss/generate-structure",
        "agent:mss/enforce-boundary",
        "agent:mss/mediate-mechanics"
      ],
      "description": "Agents decode, translate, generate, enforce, and mediate MSS fields. See mss-runtime.jsonld."
    },
    {
      "@id": "mss-seed:scale-structure-map",
      "@type": "Concept",
      "references": [
        "mss:values/scale-structure-map",
        "mss:rule/structure-scale-compatible"
      ],
      "description": "Machine-readable scale-structure compatibility constraints. See mss-values.jsonld."
    }
  ],
  "requires": [],
  "seeds": [
    {
      "@id": "seed://mss-seed-mss-fields",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-values",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-invariants",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-composition",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-runtime",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-modnet-core",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-dynamics",
      "@type": "Skill"
    }
  ]
}