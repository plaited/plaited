{
  "@id": "seed://mss-seed-mss-values",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/mss-values.jsonld",
  "layer": "seed",
  "description": "MSS canonical value concepts for each field. These are the standard value vocabulary, not a closed registry — agents may generate new realizations provided the resulting semantics remain consistent.",
  "requires": [
    { "@id": "seed://mss-seed-mss-fields", "@type": "Skill" }
  ],
  "provides": [
    {
      "@id": "mss:scale/s1",
      "@type": "Concept",
      "scaleLevel": 1,
      "description": "Singular object — single atomic item with no internal grouping. Contains nothing; contained by S2+. Examples: health metric, product listing, stateless converter, color palette.",
      "validStructures": ["object", "form"]
    },
    {
      "@id": "mss:scale/s2",
      "@type": "Concept",
      "scaleLevel": 2,
      "description": "Object group — organizes multiple items into a single group. Contains S1 objects; contained by S3+. Examples: health tracker, product catalog, portfolio, task list, playlist.",
      "validStructures": ["object", "list", "collection", "steps", "form"]
    },
    {
      "@id": "mss:scale/s3",
      "@type": "Concept",
      "scaleLevel": 3,
      "description": "Block — composes multiple groups into an interactive block with emergent dynamics. Contains S2 groups; contained by S4+. Examples: chat room, social feed, health dashboard, calendar, user profile, forum.",
      "validStructures": ["pool", "stream", "feed", "wall", "thread", "form", "collection", "steps"]
    },
    {
      "@id": "mss:scale/s4",
      "@type": "Concept",
      "scaleLevel": 4,
      "description": "Block group — arranges multiple blocks spatially. Contains S3 blocks; contained by S5+. Example: two-person collaborative canvas with pass-back between participants.",
      "validStructures": ["form"]
    },
    {
      "@id": "mss:scale/s5",
      "@type": "Concept",
      "scaleLevel": 5,
      "description": "Module — complete self-contained interactive unit. Contains S3-S4 blocks; contained by S6+. Has internal loops. Could stand alone. Examples: farm stand, community, exhibition, family space.",
      "validStructures": ["collection", "feed", "thread", "pool"]
    },
    {
      "@id": "mss:scale/s6",
      "@type": "Concept",
      "scaleLevel": 6,
      "description": "Module group — clusters multiple modules by function. Contains S5 modules; contained by S7+. Examples: farmers market, neighborhood game platform, household platform.",
      "validStructures": ["pool", "collection"]
    },
    {
      "@id": "mss:scale/s7",
      "@type": "Concept",
      "scaleLevel": 7,
      "description": "Platform structure — platform with navigation architecture. Contains S5-S6 clusters; contained by S8. Examples: company platform, social network, research platform, gallery platform.",
      "validStructures": ["hierarchy", "matrix", "daisy", "hypertext", "pool", "collection"]
    },
    {
      "@id": "mss:scale/s8",
      "@type": "Concept",
      "scaleLevel": 8,
      "description": "Super-structure — federates multiple platforms. Contains S7 platforms. Examples: decentralized education marketplace, federated social networks.",
      "validStructures": ["matrix", "pool", "collection"]
    },
    {
      "@id": "mss:scale/relative",
      "@type": "Concept",
      "description": "scale.rel — scale expressed relative to parent-child composition. May differ from the rendered user view scale."
    },
    {
      "@id": "mss:structure/object",
      "@type": "Concept",
      "description": "Single display-only item — one artwork, one weather reading, one health metric"
    },
    {
      "@id": "mss:structure/form",
      "@type": "Concept",
      "description": "Active input tool — editors, calculators, converters, trackers with input fields. Primary interaction is user creation or manipulation"
    },
    {
      "@id": "mss:structure/list",
      "@type": "Concept",
      "description": "Items in a defined order — playlists, reading lists, priority-ranked queues"
    },
    {
      "@id": "mss:structure/collection",
      "@type": "Concept",
      "description": "Items grouped without inherent order — portfolios, inventories, category groupings"
    },
    {
      "@id": "mss:structure/steps",
      "@type": "Concept",
      "description": "Items linked across pages toward a goal — wizard flows, calendar views, simulation modes"
    },
    {
      "@id": "mss:structure/pool",
      "@type": "Concept",
      "description": "Items nested under hierarchy — folders within folders, drill-down navigation"
    },
    {
      "@id": "mss:structure/stream",
      "@type": "Concept",
      "description": "Items ordered chronologically and scrollable — chat rooms, activity logs, message history"
    },
    {
      "@id": "mss:structure/feed",
      "@type": "Concept",
      "description": "Stream sorted algorithmically — social feeds, news feeds, discovery feeds"
    },
    {
      "@id": "mss:structure/wall",
      "@type": "Concept",
      "description": "Static profile info combined with collaborative stream — owned by one person"
    },
    {
      "@id": "mss:structure/thread",
      "@type": "Concept",
      "description": "Items as nested replies — branching conversation. Reddit comments, forum threads"
    },
    {
      "@id": "mss:structure/hierarchy",
      "@type": "Concept",
      "description": "Strict top-down pathways — all pathways delineated by designer. DMV website pattern"
    },
    {
      "@id": "mss:structure/matrix",
      "@type": "Concept",
      "description": "Hierarchy plus hypertext navigation — Wikipedia, Facebook multi-path navigation"
    },
    {
      "@id": "mss:structure/daisy",
      "@type": "Concept",
      "description": "Central portal with secondary loops — health tracking apps with quick-log primary goal"
    },
    {
      "@id": "mss:structure/hypertext",
      "@type": "Concept",
      "description": "User-generated search structures — Pinterest, Google discovery patterns"
    },
    {
      "@id": "mss:boundary/all",
      "@type": "Concept",
      "description": "Data flows freely to connected modules — no user data stored, or content inherently public"
    },
    {
      "@id": "mss:boundary/none",
      "@type": "Concept",
      "description": "No data leaves the module — personal data the user would not share"
    },
    {
      "@id": "mss:boundary/ask",
      "@type": "Concept",
      "description": "User prompted before sharing — social/collaborative, commerce, community with accounts"
    },
    {
      "@id": "mss:boundary/paid",
      "@type": "Concept",
      "description": "Sharing requires value exchange — research or data requiring payment"
    },
    {
      "@id": "mss:mechanics/track",
      "@type": "Concept",
      "description": "Module contains temporal data that changes over time — user-generated or external (forecasts, prices, live metrics)"
    },
    {
      "@id": "mss:mechanics/chart",
      "@type": "Concept",
      "description": "Data visualized as graphs, trends, or plots — co-occurs with track when module itself records temporal data"
    },
    {
      "@id": "mss:mechanics/filter",
      "@type": "Concept",
      "description": "Users can hide items by criteria — category, status, date range, price"
    },
    {
      "@id": "mss:mechanics/sort",
      "@type": "Concept",
      "description": "Users can reorder items by attribute — date, price, rating, priority"
    },
    {
      "@id": "mss:mechanics/post",
      "@type": "Concept",
      "description": "Users create new top-level content in a stream/feed/wall"
    },
    {
      "@id": "mss:mechanics/reply",
      "@type": "Concept",
      "description": "Users respond to existing content in a nested thread"
    },
    {
      "@id": "mss:mechanics/vote",
      "@type": "Concept",
      "description": "Content has upvote/downvote for ranking"
    },
    {
      "@id": "mss:mechanics/karma",
      "@type": "Concept",
      "description": "Accumulated reputation score across posts in a community"
    },
    {
      "@id": "mss:mechanics/gold",
      "@type": "Concept",
      "description": "Premium award from users — costs real value"
    },
    {
      "@id": "mss:mechanics/follow",
      "@type": "Concept",
      "description": "Users can subscribe to a specific source for updates"
    },
    {
      "@id": "mss:mechanics/like",
      "@type": "Concept",
      "description": "Single-direction approval signal — not ranked"
    },
    {
      "@id": "mss:mechanics/swipe",
      "@type": "Concept",
      "description": "Card-based binary decisions — one item at a time"
    },
    {
      "@id": "mss:mechanics/scarcity",
      "@type": "Concept",
      "description": "Designer-imposed cap on interactions per period"
    },
    {
      "@id": "mss:mechanics/limited-loops",
      "@type": "Concept",
      "description": "Turn-based messaging — cannot send until reply received"
    },
    {
      "@id": "mss:mechanics/share",
      "@type": "Concept",
      "description": "Export or link content externally — only when boundary is all or ask"
    },
    {
      "@id": "mss:contentType/health",
      "@type": "Concept",
      "description": "Health/fitness domain — fitness trackers, health metrics, wellness tools"
    },
    {
      "@id": "mss:contentType/health-research",
      "@type": "Concept",
      "description": "Population-level health analysis — longitudinal studies, research platforms. NOT for personal health trackers."
    },
    {
      "@id": "mss:contentType/social",
      "@type": "Concept",
      "description": "Social/chat/forum domain — posts, feeds, communities with shared content"
    },
    {
      "@id": "mss:contentType/social-identity",
      "@type": "Concept",
      "description": "Profile/reputation domain — public accumulation of user info, karma, follows. NOT for content feeds."
    },
    {
      "@id": "mss:contentType/social-ephemeral",
      "@type": "Concept",
      "description": "Proximity-based social — temporary gathering, meeting place. Disappears when user leaves range."
    },
    {
      "@id": "mss:contentType/science",
      "@type": "Concept",
      "description": "Science/simulation/stats domain — data analysis, charts, periodic tables, simulators"
    },
    {
      "@id": "mss:contentType/finance",
      "@type": "Concept",
      "description": "Finance/expenses domain — expense logging, budget tracking, ledgers"
    },
    {
      "@id": "mss:contentType/logistics",
      "@type": "Concept",
      "description": "Logistics/inventory domain — shipping, routing, inventory management"
    },
    {
      "@id": "mss:contentType/real-estate",
      "@type": "Concept",
      "description": "Real estate domain — property listings, scheduling viewings"
    },
    {
      "@id": "mss:contentType/produce",
      "@type": "Concept",
      "description": "Fresh produce/commerce domain — farm stands, farmers markets, local sellers"
    },
    {
      "@id": "mss:contentType/commerce",
      "@type": "Concept",
      "description": "General commerce domain — diverse product types, auto-assembled markets"
    },
    {
      "@id": "mss:contentType/tools",
      "@type": "Concept",
      "description": "Tools/utilities domain — calculators, calendars, converters, task lists"
    },
    {
      "@id": "mss:contentType/art",
      "@type": "Concept",
      "description": "Art/creative/design domain — palettes, galleries, drawing tools"
    },
    {
      "@id": "mss:contentType/education",
      "@type": "Concept",
      "description": "Education/learning platform domain — course platforms, federated learning networks. S8 only."
    },
    {
      "@id": "mss:contentType/education-study",
      "@type": "Concept",
      "description": "Personal writing-based reflection — reading journals, daily reactions, reflective writing trackers. NOT for flashcard decks."
    },
    {
      "@id": "mss:contentType/education-discussion",
      "@type": "Concept",
      "description": "Group discussion space — forum threads, peer replies, shared posting"
    },
    {
      "@id": "mss:contentType/work",
      "@type": "Concept",
      "description": "Work/professional domain — documents, coordination, distribution"
    },
    {
      "@id": "mss:contentType/work-creation",
      "@type": "Concept",
      "description": "Individual creation work — editors with progress tracking"
    },
    {
      "@id": "mss:contentType/work-evaluation",
      "@type": "Concept",
      "description": "Team evaluation work — review boards, critique workflows"
    },
    {
      "@id": "mss:contentType/work-coordination",
      "@type": "Concept",
      "description": "Cross-team coordination — meeting rooms, shared outputs"
    },
    {
      "@id": "mss:contentType/work-distribution",
      "@type": "Concept",
      "description": "Organizational hierarchy — company platforms with tiered access"
    },
    {
      "@id": "mss:contentType/play",
      "@type": "Concept",
      "description": "Play/games domain — solo games, entertainment"
    },
    {
      "@id": "mss:contentType/play-cocreation",
      "@type": "Concept",
      "description": "Collaborative creative exchange between specific participants — turn-based pass-and-draw tools"
    },
    {
      "@id": "mss:contentType/play-community",
      "@type": "Concept",
      "description": "Community play — game platforms with verified participation, post/vote mechanics"
    },
    {
      "@id": "mss:contentType/entertainment",
      "@type": "Concept",
      "description": "Entertainment/music domain — multi-genre platforms with creator tiers"
    },
    {
      "@id": "mss:contentType/family",
      "@type": "Concept",
      "description": "Family/household domain — shared spaces, living room patterns"
    },
    {
      "@id": "mss:contentType/household",
      "@type": "Concept",
      "description": "Household platform domain — connecting family members, bedrooms + common areas"
    },
    {
      "@id": "mss:contentType/personal",
      "@type": "Concept",
      "description": "Personal/private aggregation — bedroom patterns, private data collection"
    },
    {
      "@id": "mss:contentType/geo",
      "@type": "Concept",
      "description": "Geography/maps domain — interactive maps with markers and search"
    },
    {
      "@id": "mss:contentType/weather",
      "@type": "Concept",
      "description": "Weather domain — forecasts, dashboards, temperature visualization"
    },
    {
      "@id": "mss:contentType/news",
      "@type": "Concept",
      "description": "News/journalism domain — article feeds, discussion"
    },
    {
      "@id": "mss:values/scale-structure-map",
      "@type": "Constraint",
      "description": "Machine-readable scale-structure compatibility mapping",
      "constraints": {
        "s1": ["object", "form"],
        "s2": ["object", "list", "collection", "steps", "form"],
        "s3": ["pool", "stream", "feed", "wall", "thread", "form", "collection", "steps"],
        "s4": ["form"],
        "s5": ["collection", "feed", "thread", "pool"],
        "s6": ["pool", "collection"],
        "s7": ["hierarchy", "matrix", "daisy", "hypertext", "pool", "collection"],
        "s8": ["matrix", "pool", "collection"]
      },
      "references": ["mss:field/scale", "mss:field/structure", "mss:rule/structure-scale-compatible"]
    }
  ]
}
