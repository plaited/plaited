{
  "@id": "seed://mss-seed-mss-invariants",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/mss-invariants.jsonld",
  "layer": "seed",
  "description": "MSS invariant encoding. Boundary and scale are the strongest invariants. contentType, structure, and mechanics are more alignment-driven and negotiated rather than globally fixed.",
  "requires": [
    {
      "@id": "seed://mss-seed-mss-fields",
      "@type": "Skill"
    },
    {
      "@id": "seed://mss-seed-mss-values",
      "@type": "Skill"
    }
  ],
  "provides": [
    {
      "@id": "mss:invariant/boundary",
      "@type": "Concept",
      "invariantStrength": "strongest",
      "references": [
        "mss:field/boundary",
        "mss:boundary/all",
        "mss:boundary/none",
        "mss:boundary/ask",
        "mss:boundary/paid",
        "mss:rule/boundary-cascade"
      ],
      "description": "boundary is the strongest MSS invariant — defines what crosses module boundaries. Determines data sovereignty."
    },
    {
      "@id": "mss:invariant/scale",
      "@type": "Concept",
      "invariantStrength": "strongest",
      "references": [
        "mss:field/scale",
        "mss:scale/s1",
        "mss:scale/s2",
        "mss:scale/s3",
        "mss:scale/s4",
        "mss:scale/s5",
        "mss:scale/s6",
        "mss:scale/s7",
        "mss:scale/s8",
        "mss:rule/nesting-transitive"
      ],
      "description": "scale is the strongest MSS invariant — defines module nesting depth and what a module can contain."
    },
    {
      "@id": "mss:invariant/content-type",
      "@type": "Concept",
      "invariantStrength": "alignment-driven",
      "references": [
        "mss:field/contentType"
      ],
      "description": "contentType is alignment-driven — agents query and translate rather than requiring global fixed-value equality. Compatible contentTypes are a strong grouping hint."
    },
    {
      "@id": "mss:invariant/structure",
      "@type": "Concept",
      "invariantStrength": "alignment-driven",
      "references": [
        "mss:field/structure"
      ],
      "description": "structure is alignment-driven — in agent-mediated systems, structure may be generated rather than selected from a fixed template registry. Similar structures can often be composed."
    },
    {
      "@id": "mss:invariant/mechanics",
      "@type": "Concept",
      "invariantStrength": "alignment-driven",
      "references": [
        "mss:field/mechanics"
      ],
      "description": "mechanics is alignment-driven — capability declarations that activate based on connected structures and agent mediation. Not all declared mechanics render in all contexts."
    },
    {
      "@id": "mss:rule/boundary-cascade",
      "@type": "Rule",
      "references": [
        "mss:field/boundary",
        "mss:invariant/boundary"
      ],
      "description": "Effective boundary = min(own, parent) where restriction order is none > paid > ask > all. Boundary:none anywhere in ancestor chain blocks all data flow."
    },
    {
      "@id": "mss:rule/nesting-transitive",
      "@type": "Rule",
      "references": [
        "mss:field/scale",
        "mss:invariant/scale"
      ],
      "description": "Scale nesting is transitive: S1 inside S2 inside S3 is valid nesting."
    },
    {
      "@id": "mss:rule/scale-contains-below",
      "@type": "Rule",
      "references": [
        "mss:field/scale",
        "mss:invariant/scale"
      ],
      "description": "A module at scale N can only contain modules at scale < N"
    },
    {
      "@id": "mss:rule/scale-contained-by-above",
      "@type": "Rule",
      "references": [
        "mss:field/scale",
        "mss:invariant/scale"
      ],
      "description": "A module at scale N can only be contained by modules at scale > N"
    },
    {
      "@id": "mss:rule/no-circular-scale",
      "@type": "Rule",
      "references": [
        "mss:field/scale",
        "mss:invariant/scale"
      ],
      "description": "Scale nesting must not be circular — a module cannot contain or be contained by itself"
    },
    {
      "@id": "mss:rule/structure-scale-compatible",
      "@type": "Rule",
      "references": [
        "mss:field/structure",
        "mss:field/scale",
        "mss:values/scale-structure-map"
      ],
      "description": "structure must be compatible with the module's scale level — see scale-level structure constraints in mss-values.jsonld"
    },
    {
      "@id": "mss:rule/boundary-respects-nesting",
      "@type": "Rule",
      "references": [
        "mss:field/boundary",
        "mss:field/scale"
      ],
      "description": "Boundary constraints respect parent-child nesting — child boundary cannot exceed parent boundary in permissiveness"
    },
    {
      "@id": "mss:rule/mechanics-activation-contextual",
      "@type": "Rule",
      "references": [
        "mss:field/mechanics",
        "mss:field/structure"
      ],
      "description": "Mechanics tags declare capability potential — they activate when context, structure, and boundary support them. Same artifact may render differently when mediated by an agent."
    },
    {
      "@id": "mss:rule/mechanics-inheritance",
      "@type": "Rule",
      "references": [
        "mss:field/mechanics"
      ],
      "description": "Mechanics inheritance is bidirectional: bottom-up (child mechanics project onto parent view) and top-down (parent mechanics available to children)"
    },
    {
      "@id": "mss:rule/contentType-negotiable",
      "@type": "Rule",
      "references": [
        "mss:field/contentType",
        "mss:invariant/content-type"
      ],
      "description": "contentType values do not need global fixed-value equality — an agent may translate between contentTypes (e.g., commerce network producing health-tracking view)"
    },
    {
      "@id": "mss:rule/structure-generated",
      "@type": "Rule",
      "references": [
        "mss:field/structure",
        "mss:invariant/structure"
      ],
      "description": "In agent-mediated systems, structure may be generated on-the-fly rather than selected from a fixed template registry"
    },
    {
      "@id": "mss:composition/valid",
      "@type": "Concept",
      "references": [
        "mss:rule/structure-scale-compatible",
        "mss:rule/nesting-transitive",
        "mss:rule/boundary-cascade"
      ],
      "description": "Valid MSS field combinations — detected by constitution bThreads before module joins network"
    },
    {
      "@id": "mss:composition/invalid",
      "@type": "Concept",
      "references": [
        "mss:rule/all-fields-required",
        "mss:rule/structure-scale-compatible",
        "mss:rule/scale-contains-below"
      ],
      "description": "Invalid MSS field combinations — enforced by constitution bThreads. Examples: feed at S1, hierarchy at S2, S5 containing S6, boundary:all with health contentType."
    }
  ]
}