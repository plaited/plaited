{
  "@id": "seed://mss-seed-mss-dynamics",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/mss-dynamics.jsonld",
  "layer": "seed",
  "description": "MSS-referenced dynamics concepts from Structural-IA and Modnet. These concepts are referenced by MSS tags but not encoded directly. Captures base dynamics, loops, channels, levers, and ephemeral network duration as seed ontology anchors for downstream behavioral-factory encoding.",
  "requires": [
    { "@id": "seed://mss-seed-mss-fields", "@type": "Skill" },
    { "@id": "seed://mss-seed-mss-invariants", "@type": "Skill" }
  ],
  "provides": [
    {
      "@id": "mss:dynamics/base-dynamic",
      "@type": "Concept",
      "description": "Base dynamic = (object or person) + channel + lever. Smallest unit of interaction — one-directional transfer of information. Maps to MSS: mechanics activation, boundary semantics."
    },
    {
      "@id": "mss:dynamics/base-object-to-object",
      "@type": "Concept",
      "description": "Object-to-object base dynamic — data sync between modules. Shipping address to truck, sensor to dashboard. In agent-mediated: preserved via A2A message passing."
    },
    {
      "@id": "mss:dynamics/base-object-to-person",
      "@type": "Concept",
      "description": "Object-to-person base dynamic — object notifies person OR person inputs to object. In agent-mediated: Object -> Agent -> Person. Agent handles notifications and escalates."
    },
    {
      "@id": "mss:dynamics/base-person-to-person",
      "@type": "Concept",
      "description": "Person-to-person base dynamic — direct communication. In agent-mediated: Person -> Agent -> Agent -> Person. Each agent controls its view. View sovereignty preserved."
    },
    {
      "@id": "mss:dynamics/loop",
      "@type": "Concept",
      "description": "Loop = base dynamic + base dynamic. Call-response relationship around a single goal. Maps to MSS: mechanics composition, emergent dynamics at S3+."
    },
    {
      "@id": "mss:dynamics/loop-positive-reinforcing",
      "@type": "Concept",
      "description": "Positive reinforcing loop — user repeats same action. Example: correct answer -> score increases -> try next word. Core loop, energy directly tied to goal."
    },
    {
      "@id": "mss:dynamics/loop-negative-reinforcing",
      "@type": "Concept",
      "description": "Negative reinforcing loop — user repeats same action with frustration. Example: filter doesn't work -> retry. Non-core loop, drains energy."
    },
    {
      "@id": "mss:dynamics/loop-positive-redirective",
      "@type": "Concept",
      "description": "Positive redirective loop — user starts new loop on same platform. Example: complete tutorial -> link to next topic. Core loop, guides to next goal."
    },
    {
      "@id": "mss:dynamics/loop-negative-redirective",
      "@type": "Concept",
      "description": "Negative redirective loop — user leaves entirely. Example: paywall blocks article -> close tab. Non-core loop, indicates broken core loop."
    },
    {
      "@id": "mss:dynamics/loop-core",
      "@type": "Concept",
      "description": "Core loops have energy directly tied to user goals. Positive core loops are the target. In agent-mediated: core loops preserved, agent collapses non-core loops."
    },
    {
      "@id": "mss:dynamics/loop-non-core",
      "@type": "Concept",
      "description": "Non-core loops drain energy: signup, pagination, search interfaces. In agent-mediated: agent handles these via generative UI, reducing user energy cost."
    },
    {
      "@id": "mss:dynamics/channel",
      "@type": "Concept",
      "description": "Channel = connection between objects that determines what information flows. Maps to MSS: boundary tag semantics. Bandwidth ranges low (yes/no) to high (video call)."
    },
    {
      "@id": "mss:dynamics/channel-bandwidth",
      "@type": "Concept",
      "description": "Channel bandwidth — low (binary), medium (text), high (video+voice+context). Trust built through information exchange. Maps to MSS: boundary permissiveness."
    },
    {
      "@id": "mss:dynamics/channel-power",
      "@type": "Concept",
      "description": "Channel power dynamics — who has more information has more power. Maps to MSS: boundary determines what information crosses, agent enforces via ABAC."
    },
    {
      "@id": "mss:dynamics/lever",
      "@type": "Concept",
      "description": "Lever = tool to alter energy flow. Four types map to MSS: mechanics field capabilities. Decreases energy needed OR increases energy willing to exert."
    },
    {
      "@id": "mss:dynamics/lever-affordance",
      "@type": "Concept",
      "description": "Affordance lever — properties making interaction explicit (door handle -> pull). Decreases energy needed. Maps to MSS: structure informs rendering."
    },
    {
      "@id": "mss:dynamics/lever-structural",
      "@type": "Concept",
      "description": "Structural cue lever — visual design elements constraining/incentivizing (text box size -> tweet length). Maps to MSS: structure guides generated UI."
    },
    {
      "@id": "mss:dynamics/lever-mechanic",
      "@type": "Concept",
      "description": "Mechanic lever — designed interaction patterns (swipe, vote, scarcity). Maps to MSS: mechanics field. In agent-mediated: declared capability, realization may differ."
    },
    {
      "@id": "mss:dynamics/lever-game",
      "@type": "Concept",
      "description": "Game lever — system-wide incentive structures across mechanics (karma + gold + followers). Maps to MSS: mechanics inheritance across scales."
    },
    {
      "@id": "mss:dynamics/module-lineage",
      "@type": "Concept",
      "description": "Module lineage from Structural-IA: objects + loops = module. Interactive unit with primary goal. Maps to MSS: S5 module. In agent-era: runtime surface is services/artifacts."
    },
    {
      "@id": "mss:dynamics/block-emergence",
      "@type": "Concept",
      "description": "Block emergence: multiple modules creating interactions they don't have alone. Maps to MSS: S3 block with pool/stream/feed/wall/thread structures."
    },
    {
      "@id": "mss:dynamics/block-situated",
      "@type": "Concept",
      "description": "Situated connectedness — visual layout of block. Maps to MSS: structure field determines rendering organization."
    },
    {
      "@id": "mss:dynamics/block-system",
      "@type": "Concept",
      "description": "System connectedness — dynamic relationships between blocks. Maps to MSS: mechanics field, mechanics inheritance (top-down/bottom-up)."
    },
    {
      "@id": "mss:dynamics/mechanics-inheritance-bottom-up",
      "@type": "Concept",
      "description": "Bottom-up mechanics inheritance — child module mechanics project onto parent view. Example: food tracking -> health icons on farm stand items."
    },
    {
      "@id": "mss:dynamics/mechanics-inheritance-top-down",
      "@type": "Concept",
      "description": "Top-down mechanics inheritance — parent mechanics available to children. Example: urban planner density heatmap over individual farm stalls."
    },
    {
      "@id": "mss:dynamics/mechanics-activation",
      "@type": "Concept",
      "description": "Mechanics activation — declared capability becomes visible UI when structure and context support it. Same artifact renders differently across agents."
    },
    {
      "@id": "mss:dynamics/ephemeral-duration-spectrum",
      "@type": "Concept",
      "references": ["mss:network/ephemeral/duration-spectrum"],
      "description": "Ephemeral network duration is a spectrum, not binary: ephemeral-task (minutes-hours), ephemeral-session (hours-days), sticky-subscription (ongoing), permanent-membership."
    },
    {
      "@id": "mss:dynamics/ephemeral-control",
      "@type": "Concept",
      "description": "Ephemeral duration controlled by goal bThread lifecycle (repeat:true vs terminate), not a new MSS tag. Agent manages connection/disconnection automatically."
    },
    {
      "@id": "mss:dynamics/assembly-agent-negotiated",
      "@type": "Concept",
      "description": "Assembly is agent-initiated, not proximity-triggered: discover -> determine MSS support -> generate/adapt artifact -> persist result. ContentTypes don't need global equality."
    },
    {
      "@id": "mss:dynamics/view-sovereignty",
      "@type": "Concept",
      "description": "View sovereignty — each person's agent controls their view of the interaction. Agents are infrastructure, not participants. Person-to-person routes through agents."
    }
  ]
}
