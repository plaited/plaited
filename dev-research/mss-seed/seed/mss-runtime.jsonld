{
  "@id": "seed://mss-seed-mss-runtime",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/mss-runtime.jsonld",
  "layer": "seed",
  "description": "Agent mediation runtime concepts for MSS. How agents interpret, translate, and enforce MSS fields in sovereign node architectures. Extends mss-invariants with agent-mediated behavior.",
  "requires": [
    { "@id": "seed://mss-seed-mss-invariants", "@type": "Skill" }
  ],
  "provides": [
    {
      "@id": "agent:mss/decode",
      "@type": "Action",
      "description": "Agent decodes MSS fields from module metadata or agent card. Fields inform composition, access, and rendering decisions."
    },
    {
      "@id": "agent:mss/translate",
      "@type": "Action",
      "description": "Agent translates between contentTypes — a commerce network may produce a health-aligned view if the user cares about nutrition. Agents negotiate rather than require global equality."
    },
    {
      "@id": "agent:mss/generate-structure",
      "@type": "Action",
      "description": "Agent generates the structure realization on-the-fly — structure is not a fixed template registry in agent-mediated systems. Same module may render differently across agents."
    },
    {
      "@id": "agent:mss/enforce-boundary",
      "@type": "Action",
      "description": "Agent enforces boundary via ABAC (Attribute-Based Access Control) — evaluates requester attributes, module attributes, and context. Escalates to user only when uncertain."
    },
    {
      "@id": "agent:mss/mediate-mechanics",
      "@type": "Action",
      "description": "Agent mediates mechanics activation — declared mechanics may activate, translate, or be suppressed depending on context, structure, and boundary. Same artifact can expose different UI when mediated."
    },
    {
      "@id": "agent:mss/query-peer",
      "@type": "Action",
      "description": "Agent queries peer agent for MSS fields — contentType, structure, or mechanics — during discovery or composition negotiation"
    },
    {
      "@id": "agent:mss/discover",
      "@type": "Trigger",
      "references": ["agent:mss/query-peer", "modnet:agent-card/mss-support"],
      "description": "Agent discovers peer MSS support via agent card metadata or explicit query"
    },
    {
      "@id": "agent:mss/consent",
      "@type": "Trigger",
      "references": ["mss:boundary/ask", "agent:mss/consent"],
      "description": "Agent triggers consent flow when boundary:ask crossing is attempted"
    },
    {
      "@id": "agent:mss/violation",
      "@type": "Trigger",
      "references": ["mss:invariant/boundary", "agent:mss/violation"],
      "description": "Agent detects boundary violation — unauthorized crossing attempt blocked by constraint"
    },
    {
      "@id": "modnet:agent-card/mss-support",
      "@type": "Concept",
      "references": ["mss:field/contentType", "mss:field/boundary"],
      "description": "Agent card metadata declares MSS support — the important fact is that an agent can signal MSS awareness and negotiate alignment over A2A. Does not require exposing full MSS ontology inline."
    },
    {
      "@id": "modnet:agent-card/mss-export",
      "@type": "Concept",
      "description": "Some implementations may project selected MSS fields into agent card metadata (e.g., modnet:mss:contentType, modnet:mss:boundary). This projection is not the ontology itself."
    },
    {
      "@id": "modnet:module/internal",
      "@type": "Concept",
      "description": "Modules are internal artifacts — code, data, tools, skills, bThreads — inside the agent. Modules never cross A2A boundaries directly."
    },
    {
      "@id": "modnet:module/service-crosses",
      "@type": "Concept",
      "description": "Only services and artifacts cross A2A boundaries — the module stays internal, the output crosses the boundary"
    },
    {
      "@id": "modnet:composition/a2a-channel",
      "@type": "Concept",
      "description": "A2A messages between nodes ARE the channels — same concept as Structural-IA channels, different transport. Agent decides what to share guided by boundary tag."
    },
    {
      "@id": "modnet:composition/negotiated",
      "@type": "Concept",
      "description": "Composition is agent-initiated and negotiated — discover peer via QR scan, NFC tap, search, or direct address; determine MSS support; generate or adapt compatible artifact on-the-fly"
    },
    {
      "@id": "modnet:node/identity",
      "@type": "Concept",
      "description": "Node identity is structural: constitution + modules + Agent Card + DAC configuration. Skills are operational tools, not identity."
    },
    {
      "@id": "modnet:constitution/mac-floor",
      "@type": "Concept",
      "description": "Constitution (MAC bThreads) defines what the node cannot do — constraints the owner cannot override. MAC ratchet: org-level bThreads only add constraints, never remove."
    },
    {
      "@id": "modnet:constitution/mss-enforce",
      "@type": "Concept",
      "references": ["mss:invariant/boundary", "mss:invariant/scale", "mss:rule/all-fields-required"],
      "description": "Constitution bThreads enforce MSS invariants — boundary:none blocks all data flow, missing bridge-code is blocked, scale nesting is enforced"
    },
    {
      "@id": "modnet:access/dac-surface",
      "@type": "Concept",
      "references": ["mss:field/boundary"],
      "description": "DAC (Discretionary Access Control) — owner sets boundary tags on modules (all/none/ask/paid). Familiar mental model like Google Drive sharing."
    },
    {
      "@id": "modnet:access/abac-evaluation",
      "@type": "Concept",
      "references": ["agent:mss/enforce-boundary"],
      "description": "ABAC (Attribute-Based Access Control) — when boundary is ask, BP predicates evaluate requester attributes + module attributes + context. Owner sets policy; BP enforces deterministically."
    },
    {
      "@id": "modnet:access/payment-as-attribute",
      "@type": "Concept",
      "references": ["mss:boundary/paid"],
      "description": "boundary:paid uses HTTP 402 with x402 headers. Payment status becomes an ABAC attribute. Owner approval follows same human-in-the-loop flow as any BP-gated action."
    },
    {
      "@id": "bp:thread/mss-boundary-enforce",
      "@type": "Thread",
      "references": ["mss:boundary/ask", "agent:mss/enforce-boundary", "agent:mss/consent"],
      "description": "bThread pattern for enforcing boundary:ask with consent escalation"
    },
    {
      "@id": "bp:thread/mss-composition-negotiate",
      "@type": "Thread",
      "references": ["agent:mss/discover", "agent:mss/query-peer", "agent:mss/translate", "modnet:composition/negotiated"],
      "description": "bThread pattern for MSS-aware peer composition negotiation"
    },
    {
      "@id": "bp:thread/mss-mechanics-mediate",
      "@type": "Thread",
      "references": ["mss:field/mechanics", "agent:mss/mediate-mechanics", "mss:rule/mechanics-activation-contextual"],
      "description": "bThread pattern for agent-mediated mechanics activation"
    }
  ]
}
