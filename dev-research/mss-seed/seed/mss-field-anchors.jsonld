{
  "@context": {
    "@vocab": "https://plaited.app/mss/vocab#",
    "mss": "https://plaited.app/mss/vocab#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "derivedFrom": {
      "@id": "https://plaited.app/mss/vocab#derivedFrom",
      "@type": "@id"
    }
  },
  "@graph": [
    {
      "@id": "mss:contentType",
      "@type": "mss:FieldAnchor",
      "rdfs:label": "contentType",
      "mss:question": "What domain or semantic alignment surface is this in?",
      "mss:stability": "alignment-driven",
      "mss:valueDomain": "free-form lowercase hyphenated labels",
      "mss:role": "Cross-agent alignment signal; strong grouping hint for compatible modules",
      "mss:defaultValues": {
        "@list": [
          "health", "social", "science", "finance", "logistics", "tools",
          "art", "entertainment", "education", "geo", "weather", "news",
          "real-estate", "commerce", "produce", "work", "play", "family"
        ]
      },
      "mss:hyphenatedVariantNote": "Use {domain}-{function} when two artifacts in the same domain should not align closely",
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:structure",
      "@type": "mss:FieldAnchor",
      "rdfs:label": "structure",
      "mss:question": "How is information organized in the current realization?",
      "mss:stability": "alignment-driven",
      "mss:valueDomain": "Structural IA vocabulary: object, form, list, collection, steps, pool, stream, feed, wall, thread, hierarchy, matrix, daisy, hypertext",
      "mss:role": "Determines interaction patterns; similar structures can often be composed or translated",
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:mechanics",
      "@type": "mss:FieldAnchor",
      "rdfs:label": "mechanics",
      "mss:question": "What interactions could activate in context?",
      "mss:stability": "alignment-driven",
      "mss:valueDomain": "Capability declarations: track, chart, filter, sort, post, reply, vote, karma, gold, follow, like, swipe, scarcity, limited-loops, share",
      "mss:role": "Cross-cutting dynamics that activate based on connected structures and agent mediation",
      "mss:note": "Mechanics are capability declarations. They activate when context, structure, and boundary support them.",
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:boundary",
      "@type": "mss:FieldAnchor",
      "rdfs:label": "boundary",
      "mss:question": "What data flows across this module's boundary?",
      "mss:stability": "strong-invariant",
      "mss:valueDomain": {
        "@list": ["all", "none", "ask", "paid"]
      },
      "mss:role": "Data sovereignty policy; determines what information may flow to other modules and networks",
      "mss:restrictionOrder": ["none", "paid", "ask", "all"],
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:scale",
      "@type": "mss:FieldAnchor",
      "rdfs:label": "scale",
      "mss:question": "Where in the nesting hierarchy?",
      "mss:stability": "strong-invariant",
      "mss:valueDomain": {
        "@list": ["S1", "S2", "S3", "S4", "S5", "S6", "S7", "S8"]
      },
      "mss:role": "Composition level; determines what a module can contain and what can contain it",
      "mss:nestingRule": "A module at scale N can only be contained by modules at scale > N; a module at scale N can only contain modules at scale < N",
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:invariant_boundary-cascade",
      "@type": "mss:Invariant",
      "rdfs:label": "Boundary Cascade",
      "mss:rule": "Effective boundary = min(own, parent) where restriction order is none > paid > ask > all",
      "mss:fields": ["boundary"],
      "mss:description": "A boundary of 'none' on any ancestor forces all descendant modules to effective boundary 'none'. This is the primary data-sovereignty enforcement mechanism.",
      "mss:example": "A personal health tracker (boundary: none) inside a health dashboard (boundary: ask) retains effective boundary: none because min(none, ask) = none",
      "derivedFrom": "skills/mss/SKILL.md",
      "mss:provenance": "skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "mss:invariant_scale-nesting",
      "@type": "mss:Invariant",
      "rdfs:label": "Scale Nesting Transitivity",
      "mss:rule": "Scale nesting is transitive: S1 inside S2 inside S3 is valid. A module at scale N can only nest inside modules at scale > N.",
      "mss:fields": ["scale"],
      "mss:description": "Prevents invalid cross-scale containment. S1 objects cannot contain S2 groups; S7 platforms cannot be nested inside S3 blocks.",
      "mss:example": "Health metric (S1) inside Health tracker (S2) inside Health dashboard (S3) is valid nesting",
      "derivedFrom": "skills/mss/SKILL.md",
      "mss:provenance": "skills/mss/references/structural-ia-distilled.md"
    },
    {
      "@id": "mss:invariant_scale-structure-compatibility",
      "@type": "mss:Invariant",
      "rdfs:label": "Scale-Structure Compatibility",
      "mss:rule": "S1: object, form. S2: object, list, collection, steps, form. S3: pool, stream, feed, wall, thread, form, collection, steps. S4-S6: Any from lower scales, composed. S7: hierarchy, matrix, daisy, hypertext, pool, collection. S8: Federated compositions.",
      "mss:fields": ["scale", "structure"],
      "mss:description": "Default guidance for structure-scale pairing. Invalid combinations: feed+S1, hierarchy+S2, object+S8. Some combinations may become negotiable with agent mediation.",
      "derivedFrom": "skills/mss/SKILL.md"
    },
    {
      "@id": "mss:heuristic_contentType-alignment",
      "@type": "mss:Heuristic",
      "rdfs:label": "ContentType Alignment",
      "mss:description": "Matching or compatible contentType values are a strong signal for grouping, translation, or composition. In agent-mediated systems this is negotiated rather than globally identical.",
      "mss:fields": ["contentType"],
      "derivedFrom": "skills/mss/SKILL.md",
      "mss:provenance": "skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "mss:heuristic_mechanics-inheritance",
      "@type": "mss:Heuristic",
      "rdfs:label": "Mechanics Inheritance",
      "mss:description": "Bottom-up: child module mechanics project onto parent view (food items → health icons on farm stand). Top-down: parent mechanics available to children (density heatmap over stalls). Mechanics tags are capability declarations; activation is context-dependent.",
      "mss:fields": ["mechanics"],
      "derivedFrom": "skills/mss/SKILL.md",
      "mss:provenance": "skills/mss/references/modnet-standards-distilled.md"
    },
    {
      "@id": "mss:pattern_boundary-none-personal",
      "@type": "mss:Pattern",
      "rdfs:label": "Personal/Private Artifact",
      "mss:fields": {
        "@vocab": "https://plaited.app/mss/vocab#"
      },
      "mss:signature": {
        "contentType": ["personal", "health", "finance", "family", "{domain}-{function}"],
        "structure": ["object", "form", "collection", "list"],
        "mechanics": ["track"],
        "boundary": "none",
        "scale": ["S1", "S2", "S3"]
      },
      "mss:description": "User-owned personal data module. No data leaves the module. boundary:none is non-negotiable regardless of parent.",
      "derivedFrom": "skills/mss/references/valid-combinations.md"
    },
    {
      "@id": "mss:pattern_social-community",
      "@type": "mss:Pattern",
      "rdfs:label": "Community Module",
      "mss:signature": {
        "contentType": "social",
        "structure": ["thread", "wall", "feed"],
        "mechanics": ["vote", "karma", "reply", "post", "follow"],
        "boundary": "ask",
        "scale": ["S5", "S6"]
      },
      "mss:description": "Reddit-style community with reputation system. Karma accumulates across posts. Requires account signup (ask boundary).",
      "derivedFrom": "skills/mss/references/valid-combinations.md"
    },
    {
      "@id": "mss:pattern_commerce-market",
      "@type": "mss:Pattern",
      "rdfs:label": "Market Module",
      "mss:signature": {
        "contentType": ["produce", "commerce"],
        "structure": ["pool", "collection", "list"],
        "mechanics": ["filter", "sort", "vote"],
        "boundary": ["all", "ask"],
        "scale": ["S5", "S6"]
      },
      "mss:description": "Auto-assembling market structure. Farm stand (S5) or farmers market (S6). Items sort/filter by category, price, origin.",
      "derivedFrom": "skills/mss/references/valid-combinations.md"
    }
  ]
}
