{
  "@id": "seed://mss-seed-modnet-core",
  "@type": "Skill",
  "source": "dev-research/mss-seed/seed/modnet-core.jsonld",
  "layer": "seed",
  "description": "Modnet core concepts distilled from Modnet.md and MODNET-IMPLEMENTATION.md. Sovereign node architecture, A2A protocol bindings, and enterprise topology.",
  "provides": [
    {
      "@id": "modnet:topology/1-node-1-user",
      "@type": "Concept",
      "description": "1 node : 1 user topology — each node is one Plaited agent serving one user. No central server, no shared tenancy, no platform operator. Nodes connect peer-to-peer via A2A."
    },
    {
      "@id": "modnet:node",
      "@type": "Concept",
      "description": "A node is a Plaited agent instance: agent loop + modules + memory + constitution. Owned and controlled by one user."
    },
    {
      "@id": "modnet:module/per-repo",
      "@type": "Concept",
      "description": "Module-per-repo workspace structure — each module in modules/ has its own git init. Two layers of version history: node-level (constitution, global config, node .memory/) and module-level (code, data, module .memory/)."
    },
    {
      "@id": "modnet:module/skill-seed",
      "@type": "Concept",
      "references": ["mss:field/contentType", "mss:field/structure", "mss:field/mechanics", "mss:field/boundary", "mss:field/scale"],
      "description": "Each module generates a seed skill (named after the module) with MSS bridge-code tags in SKILL.md frontmatter metadata. PM reads metadata for module discovery — no sidecar database."
    },
    {
      "@id": "modnet:a2a/protocol",
      "@type": "Concept",
      "description": "A2A (Agent-to-Agent) is a transport-agnostic protocol for peer-to-peer agent communication. Three layers: canonical data model, abstract operations, protocol bindings."
    },
    {
      "@id": "modnet:a2a/transport/per-interaction",
      "@type": "Concept",
      "description": "A2A transport is per-interaction, not per-node — a node can use HTTP for one task and WebSocket for another with the same peer. Declarable in agent card capabilities."
    },
    {
      "@id": "modnet:a2a/transport/same-box",
      "@type": "Concept",
      "description": "Same box (k8s pod, docker-compose) — Unix domain socket. OS-level security, no network overhead."
    },
    {
      "@id": "modnet:a2a/transport/same-cluster",
      "@type": "Concept",
      "description": "Same cluster (k8s services, docker network) — TCP over internal DNS with mTLS via cert-manager or Istio."
    },
    {
      "@id": "modnet:a2a/transport/cross-network",
      "@type": "Concept",
      "description": "Cross-network (sovereign nodes) — TCP over internet with mTLS. Mutual TLS satisfies encryption requirement."
    },
    {
      "@id": "modnet:a2a/streaming",
      "@type": "Concept",
      "description": "A2A streaming uses SSE framing (text/event-stream) over POST — not GET. Browser EventSource cannot be used. Each data: line contains a JSON-RPC 2.0 response wrapping task, message, statusUpdate, or artifactUpdate."
    },
    {
      "@id": "modnet:identity/tofu",
      "@type": "Concept",
      "description": "Trust-on-first-use (TOFU) identity — first connection requires human confirmation; subsequent connections verify against stored key. Trust levels: untrusted -> tofu -> verified, or revoked."
    },
    {
      "@id": "modnet:identity/mtls",
      "@type": "Concept",
      "description": "mTLS is the natural identity fit for sovereign nodes — both sides prove identity, no third party needed. Certificate issuance via registry node."
    },
    {
      "@id": "modnet:node/role/pm",
      "@type": "Concept",
      "description": "PM (orchestrator) node — admin's sovereign control center. Orchestrates infrastructure nodes via A2A. Does not replace infrastructure nodes; uses them."
    },
    {
      "@id": "modnet:node/role/registry",
      "@type": "Concept",
      "description": "Registry node — provisions and revokes nodes, issues certificates. Constitution: cannot read worker data."
    },
    {
      "@id": "modnet:node/role/observer",
      "@type": "Concept",
      "description": "Observer node — receives and stores audit events. Constitution: cannot modify nodes."
    },
    {
      "@id": "modnet:node/role/gateway",
      "@type": "Concept",
      "description": "Gateway node — federation boundary for cross-network A2A."
    },
    {
      "@id": "modnet:node/role/worker",
      "@type": "Concept",
      "description": "Worker node — standard agent constraints plus org-level MAC. Domain-specific skills."
    },
    {
      "@id": "modnet:seed/provisioning",
      "@type": "Concept",
      "description": "Nodes are generated by seed skills — build-time specifications consumed by Claude Code. Seeds are ephemeral: generate the node, then discarded. Node identity is structural: constitution + modules + Agent Card."
    },
    {
      "@id": "modnet:seed/bootstrap",
      "@type": "Concept",
      "description": "Bootstrap: enterprise genome generates PM node (one-shot, genome archived). PM then uses registry to provision infrastructure and worker nodes."
    },
    {
      "@id": "modnet:mac/org-base",
      "@type": "Concept",
      "description": "Org distributes base constitution that ALL nodes must run — enforce audit logging, block credential sharing, require org certs. MAC ratchet: adds constraints only, never removes."
    },
    {
      "@id": "modnet:mac/role-additive",
      "@type": "Concept",
      "description": "Role-specific MAC is additive on top of org base — registry adds blockDataAccess, workers add standardFileSandbox. Owner DAC preferences layer on top but cannot weaken the org floor."
    },
    {
      "@id": "modnet:sovereignty/data-local",
      "@type": "Concept",
      "description": "User data lives on their node, nowhere else. Node going offline means data disappears from network, not from owner."
    },
    {
      "@id": "modnet:sovereignty/no-lockin",
      "@type": "Concept",
      "description": "Disconnection removes data or access from that network. Platform death does not imply data loss."
    },
    {
      "@id": "modnet:sovereignty/services-over-internals",
      "@type": "Concept",
      "description": "Sovereign agents may expose services or artifacts without exposing all module internals. Agent card is a projection of capabilities, not an inventory of internals."
    }
  ]
}
