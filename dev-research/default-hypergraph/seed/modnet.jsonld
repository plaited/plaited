{
  "@id": "seed://default-hypergraph-modnet",
  "@type": "Skill",
  "source": "dev-research/default-hypergraph/seed/modnet.jsonld",
  "layer": "seed",
  "description": "Modnet composition and assembly semantics derived from skills/modnet-modules/SKILL.md",
  "provides": [
    {
      "@id": "modnet:composition/parent-child",
      "@type": "Concept",
      "references": ["mss:scale", "mss:scale/relative"],
      "description": "Parent-child composition uses scale as the primary nesting key."
    },
    {
      "@id": "modnet:composition/auto-group",
      "@type": "Concept",
      "references": ["mss:content-type"],
      "description": "Heuristic tendency, not a universal law. Agents may align, keep distinct, or generate intermediate views."
    },
    {
      "@id": "modnet:composition/auto-promote",
      "@type": "Concept",
      "description": "Heuristic tendency, not a universal law. Scale or content promotion may be rejected based on boundary or intent."
    },
    {
      "@id": "modnet:boundary/ask",
      "@type": "Concept",
      "references": ["mss:boundary/ask"]
    },
    {
      "@id": "modnet:boundary/none",
      "@type": "Concept",
      "references": ["mss:boundary/none"]
    },
    {
      "@id": "modnet:mechanic/filter",
      "@type": "Concept",
      "references": ["mss:mechanics/filter"]
    },
    {
      "@id": "modnet:mechanic/sort",
      "@type": "Concept",
      "references": ["mss:mechanics/sort"]
    },
    {
      "@id": "modnet:mechanic/track",
      "@type": "Concept",
      "references": ["mss:mechanics/track"]
    },
    {
      "@id": "modnet:mechanic/share",
      "@type": "Concept",
      "references": ["mss:mechanics/share"]
    },
    {
      "@id": "modnet:mechanic/chart",
      "@type": "Concept",
      "references": ["mss:mechanics/chart"]
    },
    {
      "@id": "modnet:assembly/scale-nesting",
      "@type": "Concept",
      "description": "Modnet assembly follows MSS scale nesting: scale N contains scales below N and is contained by scales above N."
    },
    {
      "@id": "modnet:assembly/boundary-cascade",
      "@type": "Concept",
      "description": "Effective boundary is constrained by parent-child composition and the strongest parent restriction wins."
    }
  ],
  "requires": [
    {
      "@id": "seed://default-hypergraph-mss",
      "@type": "Skill"
    }
  ]
}
