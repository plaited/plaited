{
  "@id": "skill://default-hypergraph-runtime",
  "@type": "Skill",
  "source": "dev-research/default-hypergraph/seed/runtime.jsonld",
  "layer": "seed",
  "description": "Runtime coordination concepts: safety, boundary constraints, memory recall triggers, uncertainty propagation",
  "provides": [
    {
      "@id": "agent:action/local-tool",
      "@type": "Action",
      "description": "Execute local tool when sufficient for the task"
    },
    {
      "@id": "agent:trigger/retrieval-needed",
      "@type": "Trigger",
      "references": ["agent:state/evidence-required"],
      "description": "Trigger hypergraph recall when evidence gap detected"
    },
    {
      "@id": "agent:trigger/search-needed",
      "@type": "Trigger",
      "references": ["agent:state/uncertain"],
      "description": "Trigger web search when uncertainty exceeds threshold"
    },
    {
      "@id": "agent:trigger/ask-human-needed",
      "@type": "Trigger",
      "references": ["agent:state/uncertain", "agent:action/ask-human"],
      "description": "Trigger human escalation when uncertainty cannot be resolved"
    },
    {
      "@id": "agent:trigger/boundary-violation-detected",
      "@type": "Trigger",
      "references": ["coord:safety/boundary-constraint"],
      "description": "Trigger safety constraint when boundary crossing is unauthorized"
    },
    {
      "@id": "agent:trigger/claim-needs-verification",
      "@type": "Trigger",
      "references": ["agent:state/unsupported-claim", "agent:action/trace-claim"],
      "description": "Trigger claim tracing when unsupported claim is detected"
    },
    {
      "@id": "coord:safety/boundary-constraint",
      "@type": "Constraint",
      "description": "Safety constraint enforcing module boundaries"
    },
    {
      "@id": "coord:safety/boundary-none",
      "@type": "Constraint",
      "description": "Hard constraint: no data may cross boundary",
      "references": ["mss:boundary/none"]
    },
    {
      "@id": "coord:safety/boundary-paid",
      "@type": "Constraint",
      "description": "Constraint: data crossing requires value exchange",
      "references": ["mss:boundary/paid"]
    },
    {
      "@id": "coord:safety/boundary-ask",
      "@type": "Constraint",
      "description": "Constraint: user consent required before data crosses",
      "references": ["mss:boundary/ask"]
    },
    {
      "@id": "coord:boundary/cascade",
      "@type": "Rule",
      "description": "Effective boundary = min(own, parent) where restriction order is none > paid > ask > all",
      "references": ["mss:boundary", "modnet:composition/parent-child"]
    },
    {
      "@id": "coord:safety/no-propagate-uncertain",
      "@type": "Policy",
      "references": ["agent:state/uncertain", "agent:action/stop"],
      "description": "Do not propagate uncertain claims without flagging uncertainty"
    },
    {
      "@id": "coord:safety/block-unverified",
      "@type": "Policy",
      "references": ["agent:state/claim-unverified", "agent:action/stop"],
      "description": "Block emission of unverified claims in safety-critical contexts"
    },
    {
      "@id": "coord:memory/useful-when-contextual",
      "@type": "Concept",
      "references": ["agent:trigger/retrieval-needed"],
      "description": "Memory is useful when context matches existing session context"
    },
    {
      "@id": "coord:memory/useful-when-similar-task",
      "@type": "Concept",
      "references": ["agent:trigger/retrieval-needed"],
      "description": "Memory is useful when task matches prior decision patterns"
    },
    {
      "@id": "coord:memory/useful-when-verified",
      "@type": "Concept",
      "references": ["agent:state/claim-verified"],
      "description": "Memory recall of verified decisions strengthens new assertions"
    },
    {
      "@id": "coord:memory/prefer-symbolic-over-raw",
      "@type": "Policy",
      "references": ["coord:memory/useful-when-contextual", "coord:memory/useful-when-similar-task"],
      "description": "Prefer symbolic state representation over raw recall when both available"
    },
    {
      "@id": "coord:policy/local-before-remote",
      "@type": "Policy",
      "references": ["agent:action/local-tool", "agent:trigger/retrieval-needed", "agent:trigger/search-needed"],
      "description": "Try local tool first, then retrieval, then web search"
    },
    {
      "@id": "coord:uncertainty/propagate-verified",
      "@type": "Policy",
      "references": ["agent:state/claim-verified", "agent:state/uncertain"],
      "description": "Verified claims reduce uncertainty in downstream compositions"
    },
    {
      "@id": "coord:uncertainty/propagate-conflicting",
      "@type": "Policy",
      "references": ["agent:evidence/conflicting", "agent:state/uncertain"],
      "description": "Conflicting evidence increases uncertainty and may trigger fanout"
    }
  ],
  "requires": [
    {
      "@id": "skill://default-hypergraph-agent-policy",
      "@type": "Skill"
    }
  ]
}
