{
  "@id": "seed://default-hypergraph-mss",
  "@type": "Skill",
  "source": "dev-research/default-hypergraph/seed/mss.jsonld",
  "layer": "seed",
  "description": "MSS fixed field names and canonical value concepts derived from skills/mss/SKILL.md",
  "provides": [
    {
      "@id": "mss:content-type",
      "@type": "Tag",
      "description": "Fixed MSS field: semantic alignment surface for cross-agent grouping and translation"
    },
    {
      "@id": "mss:structure",
      "@type": "Tag",
      "description": "Fixed MSS field: information organization pattern in current realization"
    },
    {
      "@id": "mss:mechanics",
      "@type": "Tag",
      "description": "Fixed MSS field: capability declarations for interaction dynamics"
    },
    {
      "@id": "mss:boundary",
      "@type": "Tag",
      "description": "Fixed MSS field: data-sharing policy across module boundaries"
    },
    {
      "@id": "mss:scale",
      "@type": "Tag",
      "description": "Fixed MSS field: position in nesting hierarchy"
    },
    {
      "@id": "mss:scale/relative",
      "@type": "Concept",
      "description": "Scale expressed relative to parent-child composition and may differ from the scale of the rendered user view"
    },
    {
      "@id": "mss:scale/s1",
      "@type": "Concept",
      "description": "Singular object - single atomic item with no internal grouping"
    },
    {
      "@id": "mss:scale/s2",
      "@type": "Concept",
      "description": "Object group - organizes multiple items into a single group"
    },
    {
      "@id": "mss:scale/s3",
      "@type": "Concept",
      "description": "Block - composes multiple groups into an interactive block with emergent dynamics"
    },
    {
      "@id": "mss:scale/s4",
      "@type": "Concept",
      "description": "Block group - arranges multiple blocks spatially"
    },
    {
      "@id": "mss:scale/s5",
      "@type": "Concept",
      "description": "Module - complete self-contained interactive unit and the common user-facing projection level for generated views"
    },
    {
      "@id": "mss:scale/s6",
      "@type": "Concept",
      "description": "Node-level or multi-module coordination structure; often projected back to the user as an actionable s5 view"
    },
    {
      "@id": "mss:scale/s7",
      "@type": "Concept",
      "description": "Cross-node or platform coordination structure that may be present structurally while remaining invisible or rendered down to lower-scale user views"
    },
    {
      "@id": "mss:scale/s8",
      "@type": "Concept",
      "description": "Super-structure across A2A or networked nodes; usually not exposed directly as a matching user-facing view"
    },
    {
      "@id": "mss:structure/object",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/form",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/collection",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/steps",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/pool",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/list",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/stream",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/feed",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/wall",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/thread",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/hierarchy",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/matrix",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/daisy",
      "@type": "Concept"
    },
    {
      "@id": "mss:structure/hypertext",
      "@type": "Concept"
    },
    {
      "@id": "mss:mechanics/filter",
      "@type": "Concept"
    },
    {
      "@id": "mss:mechanics/share",
      "@type": "Concept"
    },
    {
      "@id": "mss:mechanics/track",
      "@type": "Concept",
      "description": "Temporal data recording - user-generated or external changes over time"
    },
    {
      "@id": "mss:mechanics/chart",
      "@type": "Concept",
      "description": "Data visualization as graphs, trends, or plots"
    },
    {
      "@id": "mss:mechanics/sort",
      "@type": "Concept",
      "description": "Reorder items by attribute (date, price, rating, priority)"
    },
    {
      "@id": "mss:mechanics/post",
      "@type": "Concept",
      "description": "Create new top-level content in a stream/feed/wall"
    },
    {
      "@id": "mss:mechanics/reply",
      "@type": "Concept",
      "description": "Respond to existing content in a nested thread"
    },
    {
      "@id": "mss:mechanics/vote",
      "@type": "Concept",
      "description": "Upvote/downvote for ranking content"
    },
    {
      "@id": "mss:mechanics/follow",
      "@type": "Concept",
      "description": "Subscribe to a specific source for updates"
    },
    {
      "@id": "mss:mechanics/like",
      "@type": "Concept",
      "description": "Single-direction approval signal (not ranked)"
    },
    {
      "@id": "mss:mechanics/swipe",
      "@type": "Concept",
      "description": "Card-based binary decisions, one item at a time"
    },
    {
      "@id": "mss:boundary/all",
      "@type": "Concept"
    },
    {
      "@id": "mss:boundary/ask",
      "@type": "Concept"
    },
    {
      "@id": "mss:boundary/none",
      "@type": "Concept"
    },
    {
      "@id": "mss:boundary/paid",
      "@type": "Concept"
    },
    {
      "@id": "mss:rule/boundary-cascade",
      "@type": "Rule",
      "description": "Effective boundary = min(own, parent) where restriction order is none > paid > ask > all"
    },
    {
      "@id": "mss:rule/structure-scale-compatible",
      "@type": "Rule",
      "description": "structure must be compatible with scale: S1-S2 objects/forms, S3+ streams/feeds/walls, S7 hierarchies"
    },
    {
      "@id": "mss:rule/nesting-transitive",
      "@type": "Rule",
      "description": "Scale nesting is transitive: S1 inside S2 inside S3 is valid"
    },
    {
      "@id": "mss:rule/scale-contains-below",
      "@type": "Rule",
      "description": "A module at scale N can only contain modules at scale < N"
    },
    {
      "@id": "mss:rule/scale-contained-by-above",
      "@type": "Rule",
      "description": "A module at scale N can only be contained by modules at scale > N"
    }
  ]
}
