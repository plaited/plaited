{
  "@context": {
    "@version": 1.1,
    "behavioral": "behavioral:",
    "constitution": "constitution:",
    "bp": "bp:",
    "rule": "rule:",
    "pattern": "pattern:",
    "derivedFrom": {
      "@id": "behavioral:derivedFrom",
      "@type": "@vocab"
    },
    "@vocab": "https://schema.org/"
  },
  "@graph": [
    {
      "@id": "bp:superStepExecutionModel",
      "@type": "Concept",
      "name": "super-step-model",
      "description": "The BP engine operates in super-steps: (1) RUN — advance all running threads to next yield, (2) COLLECT — gather requests/blocks/interrupts from pending threads, (3) SELECT — filter blocked candidates, choose highest-priority remaining, (4) NOTIFY — resume matching threads, fire handlers, advance to next step. External trigger via trigger() starts a new super-step.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md",
        "skills/behavioral-core/references/behavioral-programs.md"
      ],
      "bp:superStepPhases": ["run", "collect", "select", "notify"],
      "bp:handlerTiming": "actionPublisher fires BEFORE step() re-evaluates predicates",
      "behavioral:anchor": true
    },
    {
      "@id": "bp:eventSelectionPrecedence",
      "@type": "rule:SelectionRule",
      "name": "event-selection-precedence",
      "description": "Event selection order: (1) blocked candidates are removed first — even one blocker prevents selection, (2) among remaining candidates, lowest priority number wins, (3) external triggers always priority 0 (highest), (4) thread requests by registration order starting at priority 1.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:blockingPrecedenceOverRequest",
      "@type": "rule:SelectionRule",
      "name": "blocking-precedence-over-request",
      "description": "If ANY thread blocks an event, it cannot be selected regardless of how many threads request it. A single validation thread can veto any number of request threads. This is the fundamental coordination mechanism.",
      "derivedFrom": [
        "skills/behavioral-core/references/behavioral-programs.md"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:sharedStatePredicateVisibility",
      "@type": "rule:ExecutionRule",
      "name": "shared-state-predicate-visibility",
      "description": "actionPublisher fires handlers BEFORE step() re-evaluates predicates. State modifications in handlers ARE visible in the next selectNextEvent() call. This is how shared mutable state (simulatingIds, board Map, etc.) coordinates between handlers and bThread predicates.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:threadCannotBeReplaced",
      "@type": "rule:ThreadRule",
      "name": "thread-cannot-be-replaced",
      "description": "bThreads.set() with an existing thread name triggers a console warning and is ignored. Threads must be terminated via interrupt or generator exhaustion — there is no direct remove API. This enforces BP's additive composition principle.",
      "derivedFrom": [
        "skills/behavioral-core/references/behavioral-programs.md",
        "src/behavioral/behavioral.ts"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:ephemeralBlockVanishes",
      "@type": "rule:ThreadRule",
      "name": "ephemeral-block-vanishes",
      "description": "A block on a sync point that also has a request is ephemeral — it vanishes after the requested event fires and the thread advances. After advance, if no more rules exist, the thread is removed entirely. maxIterations alone is NOT sufficient for permanent blocking.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:asyncBridgeSuperStepBreak",
      "@type": "rule:ExecutionRule",
      "name": "async-bridge-super-step-break",
      "description": "Async handlers start executing but do NOT block the super-step — BP engine continues immediately (fire-and-forget via void cb(value)). The handler's trigger() after await starts a NEW super-step. This bridges sync BP and async I/O worlds.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md",
        "skills/behavioral-core/SKILL.md"
      ],
      "rule:classification": "behavioral-runtime-invariant"
    },
    {
      "@id": "bp:predicatePerformance",
      "@type": "rule:PerformanceRule",
      "name": "predicate-performance",
      "description": "Block/waitFor predicates are evaluated during COLLECT phase for EVERY pending thread. Keep predicates fast — simple property checks. Expensive computations belong in feedback handlers which trigger events; predicates then wait for those events.",
      "derivedFrom": [
        "skills/behavioral-core/references/behavioral-programs.md"
      ],
      "rule:classification": "performance-guideline"
    },
    {
      "@id": "bp:externalContextContracts",
      "@type": "rule:FactoryRule",
      "name": "external-context-contracts",
      "description": "Behavioral factories should prefer explicit context contracts over implicit shared mutable state where possible. Closures are acceptable for local implementations; explicit context inputs are preferred for reusable/generated factories.",
      "derivedFrom": [
        "skills/behavioral-core/references/algorithm-reference.md"
      ],
      "rule:classification": "factory-authoring-guideline"
    },
    {
      "@id": "pattern:sharedStateCoordination",
      "@type": "pattern:BehavioralPattern",
      "name": "sharedStateCoordination",
      "description": "Handlers modify shared mutable state (Set, Map, boolean flags); bThread predicates read that state during COLLECT phase. State changes made in handlers are visible to predicates in the next selectNextEvent() call due to handler-before-step ordering.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-patterns.spec.ts"
      ],
      "pattern:usesSharedState": true,
      "pattern:verified": true,
      "pattern:category": "coordination"
    },
    {
      "@id": "pattern:interruptMidSequence",
      "@type": "pattern:BehavioralPattern",
      "name": "interruptMidSequence",
      "description": "interrupt kills the thread wherever it is in its rule sequence — not just at the end. Useful for per-task threads: task ends → message fires → interrupt kills the counting thread regardless of how many events it had already counted.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-lifecycle.spec.ts"
      ],
      "pattern:verified": true,
      "pattern:category": "lifecycle"
    },
    {
      "@id": "pattern:perTaskDynamicThreads",
      "@type": "pattern:BehavioralPattern",
      "name": "perTaskDynamicThreads",
      "description": "Per-task bThreads added in feedback handlers, interrupted when task ends. Thread name is freed for re-use after interrupt. Allows each task to have its own coordination rules (maxIterations, etc.) without cross-task interference.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-lifecycle.spec.ts"
      ],
      "pattern:verified": true,
      "pattern:category": "lifecycle"
    },
    {
      "@id": "pattern:conditionalRepeatTermination",
      "@type": "pattern:BehavioralPattern",
      "name": "conditionalRepeatTermination",
      "description": "repeat: () => boolean form: bThread repeats while predicate returns true. When predicate returns false, the thread finishes its current rule sequence and is not re-added to pending — self-terminates without interrupt event.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-lifecycle.spec.ts"
      ],
      "pattern:verified": true,
      "pattern:category": "lifecycle"
    },
    {
      "@id": "pattern:staleAsyncProtection",
      "@type": "pattern:BehavioralPattern",
      "name": "staleAsyncProtection",
      "description": "taskGate blocks stale events between tasks. Async handler may complete after task ends — its trigger() call is silently blocked because taskGate is back at phase 1 (blocking). Prevents next task state corruption from previous task's async completions.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-lifecycle.spec.ts"
      ],
      "pattern:verified": true,
      "pattern:category": "safety"
    },
    {
      "@id": "pattern:restrictedTriggerBoundary",
      "@type": "pattern:BehavioralPattern",
      "name": "restrictedTriggerBoundary",
      "description": "useRestrictedTrigger creates a narrow external trigger surface. Events in the restricted set are rejected with a snapshot error message — never reach the BP engine. Internal trigger used by handlers allows all events.",
      "derivedFrom": [
        "skills/behavioral-core/references/agent-orchestration.spec.ts"
      ],
      "pattern:verified": true,
      "pattern:category": "security"
    }
  ]
}
