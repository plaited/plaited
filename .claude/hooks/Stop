#!/usr/bin/env bash

# Hook: Auto-research loop enforcement
#
# Blocks Claude from stopping during autonomous research sessions.
# Only active when PLAITED_AUTO_RESEARCH=1 is set in the environment.
#
# The agent runs until:
#   - experiment count reaches $PLAITED_MAX_EXPERIMENTS (default: 20)
#   - or the user manually interrupts (Ctrl+C)
#
# Usage:
#   PLAITED_AUTO_RESEARCH=1 PLAITED_MAX_EXPERIMENTS=50 claude

if [ "$PLAITED_AUTO_RESEARCH" != "1" ]; then
  exit 0
fi

MAX=${PLAITED_MAX_EXPERIMENTS:-20}
LOG="${CLAUDE_PROJECT_DIR:-.}/.memory/evals/experiments.jsonl"

if [ ! -f "$LOG" ]; then
  echo '{"decision":"block","reason":"Auto-research active. No experiments completed yet. Continue the calibration loop — see docs/AUTO-RESEARCH.md Variant 1."}'
  exit 0
fi

COUNT=$(wc -l < "$LOG" | tr -d ' ')

if [ "$COUNT" -ge "$MAX" ]; then
  exit 0
fi

echo "{\"decision\":\"block\",\"reason\":\"Auto-research active. ${COUNT}/${MAX} experiments completed. Continue the calibration loop.\"}"
exit 0
