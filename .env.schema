# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_SERVICE_ACCOUNT_TOKEN)
#
# Plaited dev-autoresearch secrets:
# - local and remote development: use a 1Password service account token
# - set OP_SERVICE_ACCOUNT_TOKEN in the environment that launches research
#
# ---

# @sensitive @required
OP_SERVICE_ACCOUNT_TOKEN=

# @sensitive @required
ANTHROPIC_API_KEY=op(op://plaited-dev/anthropic/api-key)

# @sensitive @required
HF_TOKEN=op(op://plaited-dev/hugging-face/api-key)

# @sensitive @required
YDC_API_KEY=op(op://plaited-dev/ydc-api-key/api-key)

# Optional local override for serving a trained Falcon LoRA adapter.
# Keep the value in a local env file or shell export rather than committing
# a timestamped run artifact path here.
FALCON_ADAPTER_PATH=
