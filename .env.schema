# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_SERVICE_ACCOUNT_TOKEN)
#
# Plaited dev-autoresearch secrets:
# - local and remote development: use a 1Password service account token
# - set OP_SERVICE_ACCOUNT_TOKEN in the environment that launches research
#
# ---

# @sensitive @required
OP_SERVICE_ACCOUNT_TOKEN=

# @sensitive @required
ANTHROPIC_API_KEY=op(op://plaited-dev/anthropic/api-key)

# Thunder Compute H100 credentials (for native-model PoC validation)
# @sensitive @required (when running native-model trials)
THUNDER_COMPUTE_API_KEY=op(op://plaited-dev/thunder-compute/api-key)
THUNDER_COMPUTE_ENDPOINT=op(op://plaited-dev/thunder-compute/endpoint)
THUNDER_COMPUTE_MODEL=meta-llama/Llama-3.1-70B
