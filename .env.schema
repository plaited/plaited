# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_TOKEN, allowAppAuth=forEnv(dev))
#
# Plaited dev-autoresearch secrets:
# - local development: prefer 1Password desktop app auth
# - CI / hosted runs: set OP_TOKEN to a 1Password service account token
#
# ---

# @type=opServiceAccountToken @sensitive
OP_TOKEN=

# @sensitive @required
ANTHROPIC_API_KEY=op(op://plaited-dev/anthropic/api-key)
