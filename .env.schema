# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_SERVICE_ACCOUNT_TOKEN)
#
# Plaited dev-autoresearch secrets:
# - local and remote development: use a 1Password service account token
# - set OP_SERVICE_ACCOUNT_TOKEN in the environment that launches research
#
# ---

# @sensitive @required
OP_SERVICE_ACCOUNT_TOKEN=

# @sensitive @required
HF_TOKEN=op(op://plaited-dev/hugging-face/api-key)

# @sensitive @required
YDC_API_KEY=op(op://plaited-dev/ydc-api-key/api-key)

# @sensitive @required
OPENROUTER_API_KEY=op(op://plaited-dev/open-router/api-key)

# Stable planning/execution/judging split for autonomous factory-program runs.
PLAITED_AUTORESEARCH_PLANNER=codex
PLAITED_EXECUTION_PROVIDER=openrouter
PLAITED_EXECUTION_MODEL=qwen/qwen3.6-plus:free
PLAITED_EXECUTION_FALLBACK_MODEL=moonshotai/kimi-k2.5
PLAITED_EXECUTION_THINKING=high
PLAITED_PROGRAM_ATTEMPTS=3
PLAITED_PROGRAM_PARALLEL=2

# Non-sensitive default model for OpenRouter-backed research/adapters.
# Override per command or shell when running judge/model ablations.
OPENROUTER_MODEL=google/gemini-3.1-pro-preview
PLAITED_PRIMARY_JUDGE_MODEL=minimax/minimax-m2.7
PLAITED_META_VERIFIER_MODEL=deepseek/deepseek-v3.2
