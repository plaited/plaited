{
  "name": "plaited",
  "version": "8.0.0-next.0",
  "license": "ISC",
  "engines": {
    "bun": ">= v1.2.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plaited/plaited.git"
  },
  "bugs": {
    "url": "https://github.com/plaited/plaited/issues"
  },
  "homepage": "https://github.com/plaited/plaited/tree/main#readme",
  "bin": {
    "plaited": "./bin/plaited.ts"
  },
  "type": "module",
  "exports": {
    "./agent": "./src/agent.ts",
    "./behavioral": "./src/behavioral.ts",
    "./cli": "./src/cli.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./mcp": "./src/mcp.ts",
    "./ui": "./src/ui.ts",
    "./utils": "./src/utils.ts"
  },
  "files": [
    "./.bin/**",
    "./AGENTS.md",
    "./skills/**",
    "./src/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run check:biome && bun run check:types && bun run check:package",
    "check:biome": "biome check",
    "check:package": "format-package --check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write && format-package --write",
    "copy:css-types": "bash scripts/copy-css-types.sh",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .hooks || true",
    "setup": "bash scripts/setup.sh",
    "setup:bun": "bash scripts/setup.sh bun",
    "setup:deps": "bash scripts/setup.sh deps",
    "setup:link": "bash scripts/setup.sh link",
    "setup:uv": "bash scripts/setup.sh uv",
    "test": "bun test"
  },
  "lint-staged": {
    "*.{js,cjs,jsx,tsx,ts}": [
      "bunx biome check --write"
    ],
    "package.json": [
      "format-package -w"
    ]
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.2",
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@youdotcom-oss/api": "^0.5.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@playwright/cli": "^0.1.9",
    "@types/beautify": "0.0.3",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "@varlock/1password-plugin": "^0.3.5",
    "axe-core": "4.11.3",
    "beautify": "0.0.8",
    "csstype": "3.2.3",
    "cz-conventional-changelog": "3.3.0",
    "format-package": "7.0.0",
    "lint-staged": "16.4.0",
    "sinon": "21.1.2",
    "typescript": "6.0.3",
    "typescript-language-server": "5.1.3",
    "varlock": "^0.9.1"
  }
}
