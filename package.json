{
  "name": "plaited",
  "version": "7.3.0-next.1",
  "license": "ISC",
  "engines": {
    "bun": ">= v1.2.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plaited/plaited.git"
  },
  "bugs": {
    "url": "https://github.com/plaited/plaited/issues"
  },
  "homepage": "https://github.com/plaited/plaited/tree/main#readme",
  "bin": {
    "plaited": "./bin/plaited.ts"
  },
  "type": "module",
  "exports": {
    "./agent": "./src/agent.ts",
    "./behavioral": "./src/behavioral.ts",
    "./cli": "./src/cli.ts",
    "./modules": "./src/modules.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./mcp": "./src/mcp.ts",
    "./ui": "./src/ui.ts",
    "./utils": "./src/utils.ts"
  },
  "files": [
    "./.bin/**",
    "./AGENTS.md",
    "./skills/**",
    "./src/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run check:biome && bun run check:types && bun run check:package",
    "check:biome": "biome check",
    "check:package": "format-package --check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write && format-package --write",
    "cline:auth": "cline auth",
    "cline:auth:openrouter": "bun scripts/cline-auth-openrouter.ts",
    "cline:version": "cline version",
    "kanban": "kanban",
    "kanban:help": "kanban --help",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .hooks || true",
    "program:autonomous": "bun scripts/run-module-programs.ts",
    "program:autonomous:dryrun": "bun scripts/run-module-programs.ts '{\"dryRun\":true}'",
    "program:autonomous:test": "bun scripts/run-module-programs.ts '{\"test\":true}'",
    "program:module": "bun run ./bin/plaited.ts program-runner",
    "test": "bun test"
  },
  "lint-staged": {
    "*.{js,cjs,jsx,tsx,ts}": [
      "bunx biome check --write"
    ],
    "package.json": [
      "format-package -w"
    ]
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@youdotcom-oss/api": "^0.5.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@mariozechner/pi-coding-agent": "^0.65.2",
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@playwright/cli": "^0.1.7",
    "@types/beautify": "0.0.3",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "@varlock/1password-plugin": "^0.3.5",
    "assemblyscript": "^0.28.14",
    "axe-core": "4.11.3",
    "beautify": "0.0.8",
    "cline": "^2.14.0",
    "csstype": "3.2.3",
    "cz-conventional-changelog": "3.3.0",
    "format-package": "7.0.0",
    "kanban": "^0.1.60",
    "lint-staged": "16.4.0",
    "sinon": "21.1.2",
    "typescript": "6.0.2",
    "typescript-language-server": "5.1.3",
    "varlock": "^0.7.4"
  }
}
