{
  "$schema": "./adapter-schema.json",
  "name": "codex",
  "description": "OpenAI Codex CLI with JSON output",
  "command": ["codex", "--approval-mode", "full-auto", "--json"],
  "promptArg": "--prompt",
  "cwdArg": "--cwd",
  "streamFormat": "ndjson",
  "eventMapping": {
    "message": {
      "match": { "type": "message", "role": "assistant" },
      "content": "$.content[?(@.type=='output_text')].text"
    },
    "thinking": {
      "match": { "type": "message", "role": "assistant" },
      "content": "$.content[?(@.type=='reasoning')].text"
    },
    "tool_call": {
      "match": { "type": "function_call" },
      "name": "$.name",
      "input": "$.arguments",
      "id": "$.call_id"
    },
    "tool_result": {
      "match": { "type": "function_call_output" },
      "output": "$.output",
      "toolCallId": "$.call_id"
    },
    "result": {
      "match": { "type": "response.completed" },
      "output": "$.response.output_text",
      "inputTokens": "$.response.usage.input_tokens",
      "outputTokens": "$.response.usage.output_tokens"
    }
  },
  "exitCodeMapping": {
    "success": [0],
    "timeout": [124]
  }
}
